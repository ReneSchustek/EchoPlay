<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EchoPlay.App.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    Title="EchoPlay">

    <Grid Background="#FFFFFF" xml:lang="de-DE">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16">

            <Image
                x:Name="LogoImage"
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                Stretch="Uniform"
                automation:AutomationProperties.AccessibilityView="Raw"
                automation:AutomationProperties.Name=""/>

            <TextBlock
                Text="EchoPlay"
                FontSize="30"
                FontWeight="Bold"
                Foreground="#1D5274"
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Uid="SplashTagline"
                FontSize="13"
                Foreground="#3A7A9C"
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Name="VersionTextBlock"
                FontSize="11"
                Foreground="#6A9AB8"
                HorizontalAlignment="Center"/>

            <ProgressBar
                IsIndeterminate="True"
                Width="200"
                Margin="0,8,0,0"
                Foreground="#1D5274"/>

            <TextBlock
                x:Name="StatusTextBlock"
                FontSize="11"
                Foreground="#3A7A9C"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"/>

        </StackPanel>
    </Grid>

</Window>
