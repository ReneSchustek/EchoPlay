<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:EchoPlay.App.ViewModels"
    xmlns:ctrl="using:EchoPlay.App.Controls">

    <Page.Resources>
        <!-- Pfeil-Button für die Favoriten-Sektion (ListView mit Drag-and-Drop, eigene Pfeile).
             Die anderen Kachelreihen nutzen das HorizontalTileRowControl mit eingebautem Style. -->
        <Style x:Key="ScrollArrowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Tile-Template für Neuerscheinungen: Cover, Badge, Kontextmenü, Progress, Overlay. -->
        <DataTemplate x:Key="NewEpisodeTileTemplate" x:DataType="viewmodels:NewEpisodeCardViewModel">
            <Grid Width="160" Height="160" CornerRadius="8">
                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,160,160"/>
                </Grid.Clip>

                <!-- Cover als klickbare Schaltfläche -->
                <Button Width="160" Height="160" Padding="0"
                        Command="{x:Bind PlayCommand}" CornerRadius="8">
                    <Image Source="{x:Bind CoverImage}" Width="160" Height="160" Stretch="UniformToFill"/>
                </Button>

                <!-- Badge oben links: "Angekündigt" (blau) oder "Neu" (grün) -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="4,4,0,0" CornerRadius="4"
                        Background="{x:Bind BadgeBrush}" Padding="6,2"
                        Visibility="{x:Bind BadgeVisibility}">
                    <TextBlock Text="{x:Bind BadgeText}" Foreground="White"
                               FontSize="10" FontWeight="SemiBold"/>
                </Border>

                <!-- Grüner Haken (nur wenn gehört) -->
                <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="LimeGreen"
                          HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,6,0,0"
                          Visibility="{x:Bind CompletedCheckVisibility, Mode=OneWay}"/>

                <!-- Kontextmenü oben rechts -->
                <Button Content="&#xE712;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Width="28" Height="28" Padding="0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,4,4,0" CornerRadius="4"
                        Background="#88000000" Foreground="White">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="DashboardMenuMarkPlayed"
                                            Command="{x:Bind MarkAsPlayedCommand}"/>
                            <MenuFlyoutItem x:Uid="DashboardMenuMarkUnplayed"
                                            Command="{x:Bind MarkAsUnplayedCommand}"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- Text-Overlay -->
                <Border VerticalAlignment="Bottom" Background="#AA000000"
                        CornerRadius="0,0,8,8" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="{x:Bind SeriesName}" Foreground="#BBFFFFFF" FontSize="10"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind InfoLineText}" Foreground="#BBFFFFFF" FontSize="10"
                                   Visibility="{x:Bind InfoLineVisibility}"/>
                        <TextBlock Text="{x:Bind EpisodeTitle}" Foreground="White" FontSize="12"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Fortschrittsbalken -->
                <ProgressBar VerticalAlignment="Bottom" Value="{x:Bind ProgressPercent, Mode=OneWay}"
                             Maximum="100" IsIndeterminate="False"
                             Visibility="{x:Bind ProgressBarVisibility, Mode=OneWay}" Height="3"/>
            </Grid>
        </DataTemplate>

        <!-- Tile-Template für In-Progress: kein Badge, kein Kontextmenü, sonst wie Neuerscheinungen. -->
        <DataTemplate x:Key="InProgressTileTemplate" x:DataType="viewmodels:NewEpisodeCardViewModel">
            <Grid Width="160" Height="160" CornerRadius="8">
                <Grid.Clip><RectangleGeometry Rect="0,0,160,160"/></Grid.Clip>
                <Button Width="160" Height="160" Padding="0"
                        Command="{x:Bind PlayCommand}" CornerRadius="8">
                    <Image Source="{x:Bind CoverImage}" Width="160" Height="160" Stretch="UniformToFill"/>
                </Button>
                <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="LimeGreen"
                          HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,6,0,0"
                          Visibility="{x:Bind CompletedCheckVisibility, Mode=OneWay}"/>
                <Border VerticalAlignment="Bottom" Background="#AA000000"
                        CornerRadius="0,0,8,8" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="{x:Bind EpisodeNumberText}" Foreground="#BBFFFFFF" FontSize="10"/>
                        <TextBlock Text="{x:Bind EpisodeTitle}" Foreground="White" FontSize="12"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <ProgressBar VerticalAlignment="Bottom" Value="{x:Bind ProgressPercent, Mode=OneWay}"
                             Maximum="100" IsIndeterminate="False"
                             Visibility="{x:Bind ProgressBarVisibility, Mode=OneWay}" Height="3"/>
            </Grid>
        </DataTemplate>

        <!-- Tile-Template für "Weiterhören": Serie + Restanzeige. -->
        <DataTemplate x:Key="UnheardSeriesTileTemplate" x:DataType="viewmodels:UnheardSeriesCardViewModel">
            <Grid Width="160" Height="160" CornerRadius="8">
                <Grid.Clip><RectangleGeometry Rect="0,0,160,160"/></Grid.Clip>
                <Button Width="160" Height="160" Padding="0" Background="Transparent"
                        BorderThickness="0" Click="OnUnheardSeriesClick"
                        Tag="{x:Bind SeriesId}" CornerRadius="8">
                    <Image Source="{x:Bind CoverImage}" Width="160" Height="160" Stretch="UniformToFill"/>
                </Button>
                <Border VerticalAlignment="Bottom" Background="#AA000000"
                        CornerRadius="0,0,8,8" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="{x:Bind SeriesName}" Foreground="White" FontSize="12"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind DisplayText}" Foreground="#BBFFFFFF" FontSize="10"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Tile-Template für "Zuletzt gehört": Serie + letzte Episode. -->
        <DataTemplate x:Key="RecentSeriesTileTemplate" x:DataType="viewmodels:RecentSeriesCardViewModel">
            <Grid Width="160" Height="160" CornerRadius="8">
                <Grid.Clip><RectangleGeometry Rect="0,0,160,160"/></Grid.Clip>
                <Button Width="160" Height="160" Padding="0" Background="Transparent"
                        BorderThickness="0" Click="OnRecentSeriesClick"
                        Tag="{x:Bind SeriesId}" CornerRadius="8">
                    <Image Source="{x:Bind CoverImage}" Width="160" Height="160" Stretch="UniformToFill"/>
                </Button>
                <Border VerticalAlignment="Bottom" Background="#AA000000"
                        CornerRadius="0,0,8,8" Padding="6,4">
                    <StackPanel>
                        <TextBlock Text="{x:Bind SeriesName}" Foreground="White" FontSize="12"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind LastEpisodeTitle}" Foreground="#BBFFFFFF" FontSize="10"
                                   MaxLines="1" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>

        <!-- Hilfe-Button oben rechts -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Background="Transparent" Padding="6" Canvas.ZIndex="1">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Inhaltsbereich: scrollbare Kachelreihen -->
        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" Margin="24">

                <!-- Startup-Hinweise: Online-/Lokal-Probleme, die im Splash erkannt wurden -->
                <InfoBar
                    x:Name="OnlineHintBar"
                    x:Uid="StartupOnlineHint"
                    Severity="Warning"
                    IsOpen="False"
                    IsClosable="True"/>
                <InfoBar
                    x:Name="LocalLibraryHintBar"
                    x:Uid="StartupLocalLibraryHint"
                    Severity="Warning"
                    IsOpen="False"
                    IsClosable="True"/>

                <!-- Abschnitt: Neuerscheinungen – gruppiert nach Serie, eine Reihe pro Serie.
                     Überschrift bleibt sichtbar während des Ladens UND wenn Ergebnisse vorliegen. -->
                <TextBlock
                    x:Uid="DashboardHeadingNew"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.NewReleasesSectionVisibility, Mode=OneWay}"/>

                <!-- Lade-Hinweis für Neuerscheinungen: sichtbar solange die iTunes-API
                     im Hintergrund abgefragt wird und noch keine Ergebnisse vorliegen -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.NewReleasesLoadingVisibility, Mode=OneWay}">
                    <ProgressRing IsActive="True" Width="16" Height="16"/>
                    <TextBlock
                        x:Uid="DashboardLoadingNewReleases"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Hinweis wenn keine Favoriten gesetzt – erscheint statt der leeren Kachelreihe -->
                <TextBlock
                    x:Uid="DashboardNoFavoritesHint"
                    Visibility="{x:Bind ViewModel.NoFavoritesHintVisibility, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- Neuerscheinungen: monatlich gruppiert – "Angekündigt" ganz oben,
                     dann Monate absteigend (neuester zuerst). -->
                <ItemsControl
                    ItemsSource="{x:Bind ViewModel.NewEpisodeGroups, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.NewEpisodeGroupsVisibility, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:NewEpisodesGroupViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock
                                    Text="{x:Bind GroupLabel}"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Margin="0,0,0,8"/>
                                <ctrl:HorizontalTileRowControl
                                    ItemsSource="{x:Bind Episodes}"
                                    ItemTemplate="{StaticResource NewEpisodeTileTemplate}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Abschnitt: Favoriten – nur einblenden wenn favorisierte Serien vorhanden -->
                <TextBlock
                    x:Uid="DashboardHeadingFavorites"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.FavoriteSectionVisibility, Mode=OneWay}"/>

                <!-- Favoriten-Kacheln: ListView statt ItemsControl, damit CanReorderItems
                     die Kacheln per Drag & Drop umsortierbar macht.
                     ItemsStackPanel Orientation=Horizontal sorgt für eine einzeilige Kachelreihe. -->
                <Grid Visibility="{x:Bind ViewModel.FavoriteSectionVisibility, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ScrollArrowButtonStyle}"
                        Tag="left" Click="OnFavoritesArrowClick" Visibility="Collapsed" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                    </Button>
                    <ListView Grid.Column="1"
                        ItemsSource="{x:Bind ViewModel.FavoriteSeries, Mode=OneWay}"
                        CanReorderItems="True"
                        AllowDrop="True"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemClick="OnFavoriteSeriesItemClick"
                        ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Enabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        Loaded="OnFavoritesListViewLoaded">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <!-- Hover/Selection-Hintergrund unsichtbar, Abstand zwischen Kacheln per Margin -->
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:FavoriteSeriesCardViewModel">
                                <!-- Kein Button als Wrapper – ein Full-Size-Button schluckt alle Pointer-Events
                                     und verhindert, dass das ListView den Drag starten kann.
                                     Navigation zur Detailseite läuft über ListView.ItemClick. -->
                                <Grid Width="160" Height="160" CornerRadius="8">
                                    <Grid.Clip><RectangleGeometry Rect="0,0,160,160"/></Grid.Clip>
                                    <Image Source="{x:Bind CoverImage}" Width="160" Height="160" Stretch="UniformToFill"/>

                                    <!-- Drag-Handle oben links: signalisiert Verschiebbarkeit.
                                         Gleicher Gripper wie bei den Neuerscheinungen (E700). -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="4,4,0,0" CornerRadius="4" Background="#88000000" Padding="4,2">
                                        <FontIcon Glyph="&#xE700;" FontSize="10" Foreground="White"/>
                                    </Border>

                                    <!-- Kontextmenü oben rechts -->
                                    <Button Content="&#xE712;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Width="28" Height="28" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,4,4,0" CornerRadius="4" Background="#88000000" Foreground="White">
                                        <Button.Flyout><MenuFlyout>
                                            <MenuFlyoutItem x:Uid="DashboardMenuRemoveFavorite" Command="{x:Bind RemoveFromFavoritesCommand}"/>
                                        </MenuFlyout></Button.Flyout>
                                    </Button>
                                    <Border VerticalAlignment="Bottom" Background="#AA000000" CornerRadius="0,0,8,8" Padding="6,4">
                                        <TextBlock Text="{x:Bind SeriesName}" Foreground="White" FontSize="12"
                                            MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Grid.Column="2" Style="{StaticResource ScrollArrowButtonStyle}"
                        Tag="right" Click="OnFavoritesArrowClick" Visibility="Collapsed" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Abschnitt: Weiterhören – Serien mit mindestens 1 gehörten + ungehörten Folgen -->
                <TextBlock
                    x:Uid="DashboardHeadingUnheard"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.UnheardSectionVisibility, Mode=OneWay}"/>

                <ctrl:HorizontalTileRowControl
                    Visibility="{x:Bind ViewModel.UnheardSectionVisibility, Mode=OneWay}"
                    ItemsSource="{x:Bind ViewModel.UnheardSeries, Mode=OneWay}"
                    ItemTemplate="{StaticResource UnheardSeriesTileTemplate}"/>

                <!-- Abschnitt: Läuft gerade – nur einblenden wenn Episoden mit Fortschritt vorhanden -->
                <TextBlock
                    x:Uid="DashboardHeadingInProgress"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.InProgressSectionVisibility, Mode=OneWay}"/>

                <ctrl:HorizontalTileRowControl
                    Visibility="{x:Bind ViewModel.InProgressSectionVisibility, Mode=OneWay}"
                    ItemsSource="{x:Bind ViewModel.InProgressEpisodes, Mode=OneWay}"
                    ItemTemplate="{StaticResource InProgressTileTemplate}"/>

                <!-- Abschnitt: Zuletzt gehört – nur einblenden wenn Einträge vorhanden -->
                <TextBlock
                    x:Uid="DashboardHeadingRecent"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.RecentSectionVisibility, Mode=OneWay}"/>

                <ctrl:HorizontalTileRowControl
                    Visibility="{x:Bind ViewModel.RecentSectionVisibility, Mode=OneWay}"
                    ItemsSource="{x:Bind ViewModel.RecentSeries, Mode=OneWay}"
                    ItemTemplate="{StaticResource RecentSeriesTileTemplate}"/>

                <!-- Ankündigungs-Sektion entfernt: Ankündigungen sind jetzt als "Angekündigt"-Gruppe
                     in den Neuerscheinungen integriert (monatliche Gruppierung, ganz oben). -->

            </StackPanel>
        </ScrollViewer>

        <!-- Lade-Indikator überlagert den Inhalt während des Ladens -->
        <ProgressRing
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipDashboard"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>

</Page>
