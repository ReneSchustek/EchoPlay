<?xml version="1.0" encoding="utf-8"?>
<!-- Wiederverwendbare Folgen-Kachel (140×140) – gleiche Größe wie Serien-Kacheln.
     Wird in lokaler und Online-Mediathek identisch verwendet. -->
<UserControl
    x:Class="EchoPlay.App.Controls.EpisodeTileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="140" Height="140" Margin="4" CornerRadius="4"
          Tapped="OnTileTapped" Background="Transparent">
        <Grid.Clip>
            <RectangleGeometry Rect="0,0,140,140"/>
        </Grid.Clip>

        <!-- Cover-Bild -->
        <Image
            x:Name="CoverImageElement"
            Stretch="UniformToFill"/>

        <!-- Platzhalter wenn kein Cover -->
        <Border
            x:Name="PlaceholderBorder"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <FontIcon
                Glyph="&#xE8D6;"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Border>

        <!-- Text-Overlay unten -->
        <Border
            VerticalAlignment="Bottom"
            Background="#AA000000"
            CornerRadius="0,0,4,4"
            Padding="6,4">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3">
                    <!-- Gehört-Häkchen -->
                    <FontIcon
                        x:Name="CompletedIcon"
                        Glyph="&#xE73E;"
                        FontSize="10"
                        Foreground="LimeGreen"
                        Visibility="Collapsed"/>
                    <TextBlock
                        x:Name="StatusText"
                        Foreground="#BBFFFFFF"
                        FontSize="10"/>
                </StackPanel>
                <TextBlock
                    x:Name="TitleText"
                    Foreground="White"
                    FontSize="12"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Aktions-Button oben rechts (konfigurierbar: "..." oder Browser-Icon) -->
        <Button
            x:Name="ActionButton"
            FontFamily="{ThemeResource SymbolThemeFontFamily}"
            Width="28" Height="28" Padding="0"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,4,4,0" CornerRadius="4"
            Background="#88000000" Foreground="White"
            Visibility="Collapsed"/>
    </Grid>
</UserControl>
