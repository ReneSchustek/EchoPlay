<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Suchzeile -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <TextBox
                x:Uid="ImportSearchBox"
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                Width="400"
                KeyDown="OnSearchBoxKeyDown"/>
            <Button
                x:Uid="ImportSearchButton"
                Click="OnSearchClick"
                IsEnabled="{x:Bind ViewModel.IsSearchEnabled, Mode=OneWay}">
                <FontIcon Glyph="&#xE721;" FontSize="16"/>
            </Button>
        </StackPanel>

        <!-- Ergebnisliste -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ImportResultViewModel">
                    <Grid Padding="4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image
                            Grid.Column="0"
                            Source="{x:Bind CoverImage}"
                            Height="60"
                            Width="60"
                            Stretch="UniformToFill"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ScoreText}" Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            x:Uid="ImportResultImportButton"
                            Command="{x:Bind ImportCommand}"
                            Visibility="{x:Bind ImportButtonVisibility}">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        </Button>

                        <TextBlock
                            Grid.Column="3"
                            x:Uid="ImportResultAlreadyImported"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Visibility="{x:Bind AlreadyImportedTextVisibility}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Statuszeile -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                Width="20"
                Height="20"/>
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsImporting, Mode=OneWay}"
                Width="20"
                Height="20"/>
            <TextBlock
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>

</Page>
