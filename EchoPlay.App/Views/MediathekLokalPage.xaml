<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.MediathekLokalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels"
    xmlns:ctrl="using:EchoPlay.App.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hilfe -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Background="Transparent" Padding="6" Canvas.ZIndex="1">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Scan-Hinweis: erscheint während ein Scan oder eine Neu-Initialisierung läuft.
             Kurze, neutrale Meldung oben – Details stehen in der Statusleiste unten. -->
        <InfoBar
            Grid.Row="0"
            x:Uid="LokalScanningHint"
            IsOpen="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
            IsClosable="False"
            Severity="Informational"
            Margin="8,8,8,0"/>

        <!-- Hinweis: wird nur angezeigt, wenn noch kein Bibliotheksordner konfiguriert ist -->
        <InfoBar
            Grid.Row="1"
            x:Uid="LokalNoFolderHint"
            IsOpen="{x:Bind ViewModel.NeedsLibraryFolderSetup, Mode=OneWay}"
            IsClosable="False"
            Severity="Informational"
            Margin="8,4,8,0">
            <InfoBar.ActionButton>
                <Button x:Uid="LokalPickFolderButton" Click="OnPickFolderClick"/>
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Bibliothekspfad, Suche und Scan-Aktionen -->
        <Grid Grid.Row="2" Padding="16,12,16,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Suchfeld: filtert die Serien-Kacheln clientseitig -->
            <AutoSuggestBox
                Grid.Column="0"
                x:Uid="LokalSearchBox"
                QueryIcon="Find"
                Text="{x:Bind ViewModel.LocalSearchText, Mode=TwoWay}"
                Width="250"
                VerticalAlignment="Center"
                TextChanged="OnLocalSearchTextChanged"/>

            <!-- Pfadanzeige: zeigt den konfigurierten Wurzelpfad der lokalen Bibliothek -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Uid="LokalLibraryPathLabel"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.LibraryRootPath, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    ToolTipService.ToolTip="{x:Bind ViewModel.LibraryRootPath, Mode=OneWay}"/>
            </StackPanel>

            <!-- Scan: Sync-Icon statt Lupe, damit es nicht mit Suche verwechselt wird -->
            <Button
                Grid.Column="2"
                ToolTipService.ToolTip="Bibliothek scannen"
                Command="{x:Bind ViewModel.ScanCommand}"
                IsEnabled="{x:Bind ViewModel.IsNotScanning, Mode=OneWay}">
                <FontIcon Glyph="&#xE895;" FontSize="16"/>
            </Button>

            <!-- Neu-Initialisierung: löscht alle Zuordnungen und baut sie komplett neu auf -->
            <Button
                Grid.Column="3"
                ToolTipService.ToolTip="Neu-Initialisierung (alle lokalen Zuordnungen zurücksetzen)"
                Command="{x:Bind ViewModel.ReInitializeCommand}"
                IsEnabled="{x:Bind ViewModel.IsNotScanning, Mode=OneWay}">
                <FontIcon Glyph="&#xE777;" FontSize="16"/>
            </Button>

            <!-- Manuell: Ordner direkt als lokale Serie anlegen, ohne vollständigen Scan -->
            <Button
                Grid.Column="4"
                ToolTipService.ToolTip="Ordner manuell hinzufügen"
                Click="OnAddFolderClick"
                IsEnabled="{x:Bind ViewModel.IsNotScanning, Mode=OneWay}">
                <FontIcon Glyph="&#xE8F4;" FontSize="16"/>
            </Button>

            <!-- Alle Serien auf fehlende Folgen prüfen (lokal + online) -->
            <Button
                Grid.Column="5"
                x:Uid="LokalCheckAllSeriesButton"
                Command="{x:Bind ViewModel.CheckAllSeriesCommand}"
                IsEnabled="{x:Bind ViewModel.IsNotScanning, Mode=OneWay}">
                <FontIcon Glyph="&#xE762;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Fortschrittsbalken: deterministisch wenn Serien- oder Dateianzahl bekannt,
             sonst indeterministisch. Sichtbar nur während eines aktiven Scans. -->
        <ProgressBar
            Grid.Row="3"
            IsIndeterminate="{x:Bind ViewModel.IsScanIndeterminate, Mode=OneWay}"
            Value="{x:Bind ViewModel.ScanProgressPercent, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsScanningVisibility, Mode=OneWay}"
            Margin="8,0,8,4"/>

        <!-- Row 4: Akkordeon-Inhalt – Serien-Grid aufgeteilt um das Folgen-Panel -->
        <!-- Episoden-Header: fixiert außerhalb des ScrollViewers, scrollt nicht mit -->
        <StackPanel Grid.Row="4" Padding="16,4,16,4"
                    Visibility="{x:Bind ViewModel.EpisodesAccordionVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Uid="LokalEpisodesHeader"
                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                    <Button x:Uid="LokalCloseEpisodesButton"
                            Click="OnCloseEpisodePanelClick"
                            Background="Transparent" BorderThickness="0" Padding="4"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE711;" FontSize="12"/>
                    </Button>
                </StackPanel>
                <ComboBox Grid.Column="1" MinWidth="120"
                          SelectedIndex="{x:Bind ViewModel.EpisodeFilterIndex, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.EpisodesLoadedVisibility, Mode=OneWay}">
                    <ComboBoxItem x:Uid="LokalFilterAll"/>
                    <ComboBoxItem x:Uid="LokalFilterUnheard"/>
                    <ComboBoxItem x:Uid="LokalFilterHeard"/>
                    <ComboBoxItem x:Uid="LokalFilterInProgress"/>
                </ComboBox>
                <ComboBox Grid.Column="2" MinWidth="140"
                          SelectedIndex="{x:Bind ViewModel.EpisodeSortIndex, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.EpisodesLoadedVisibility, Mode=OneWay}">
                    <ComboBoxItem x:Uid="LokalSortByNumber"/>
                    <ComboBoxItem x:Uid="LokalSortByNumberDesc"/>
                    <ComboBoxItem x:Uid="LokalSortByTitle"/>
                </ComboBox>
                <Button Grid.Column="3"
                        ToolTipService.ToolTip="Alle Tracks dieser Serie im Tag-Manager bearbeiten"
                        Command="{x:Bind ViewModel.OpenAllSeriesTracksCommand}"
                        Visibility="{x:Bind ViewModel.SeriesActionsVisibility, Mode=OneWay}">
                    <FontIcon Glyph="&#xE8EC;" FontSize="14"/>
                </Button>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="4" Padding="0,0"
                        Visibility="{x:Bind ViewModel.HasSpecialEpisodes, Mode=OneWay}">
                <RadioButton x:Uid="LokalTabEpisodes" GroupName="EpisodeTab"
                             IsChecked="True" Checked="OnEpisodeTabRegularChecked"/>
                <RadioButton GroupName="EpisodeTab" Checked="OnEpisodeTabSpecialChecked">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Uid="LokalTabSpecial"/>
                        <TextBlock Text="("/>
                        <TextBlock Text="{x:Bind ViewModel.SpecialEpisodeCount, Mode=OneWay}"/>
                        <TextBlock Text=")"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
            <TextBlock x:Uid="LokalEpisodesEmpty"
                       Visibility="{x:Bind ViewModel.EpisodesEmptyVisibility, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="16,16,16,0" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="5">
            <StackPanel Padding="8">

                <!-- Leer-Hinweis wenn noch kein Scan durchgeführt -->
                <TextBlock
                    x:Uid="LokalArtistsEmpty"
                    Visibility="{x:Bind ViewModel.ArtistsEmptyVisibility, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="16,32,16,0"
                    TextWrapping="Wrap"/>

                <!-- Serien – oberer Teil (Kacheln vor der ausgewählten Reihe) -->
                <GridView
                    x:Name="SeriesTopGrid"
                    SelectionMode="Single"
                    SelectionChanged="OnArtistSelectionChanged"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" ItemWidth="148" ItemHeight="166"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LocalArtistCardViewModel">
                            <ctrl:SeriesTileControl
                                CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                Title="{x:Bind Title, Mode=OneTime}"
                                Subtitle="{x:Bind CountText, Mode=OneTime}"
                                FavoriteVisibility="Visible"
                                FavoriteGlyph="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                FavoriteCommand="{x:Bind ToggleFavoriteCommand}"
                                WatchedVisibility="{x:Bind WatchedVisibility, Mode=OneWay}"
                                WatchedGlyph="{x:Bind WatchedGlyph, Mode=OneTime}"
                                SelectedIndicatorVisibility="{x:Bind SelectedIndicatorVisibility, Mode=OneWay}">
                                <ctrl:SeriesTileControl.ContextFlyoutMenu>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Uid="SeriesDetailsItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesDetailsClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE946;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <ToggleMenuFlyoutItem
                                            x:Uid="WatchSeriesItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            IsChecked="{x:Bind IsWatched, Mode=OneWay}"
                                            Click="OnToggleWatchSeriesClick">
                                            <ToggleMenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE7B3;"/>
                                            </ToggleMenuFlyoutItem.Icon>
                                        </ToggleMenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalMarkAllAsReadItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnMarkAllAsReadClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalMissingEpisodesItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnShowMissingEpisodesClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalRemoveFromLibraryItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnRemoveSeriesFromLibraryClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalDeleteFromDiskItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnDeleteSeriesFromDiskClick"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalSeriesCoverSelectItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesCoverSelectClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalSeriesCoverSearchItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesCoverSearchClick"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalRestructureItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnRestructureClick"/>
                                    </MenuFlyout>
                                </ctrl:SeriesTileControl.ContextFlyoutMenu>
                            </ctrl:SeriesTileControl>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Akkordeon: EpisodeAccordionControl + Track-Panel nebeneinander -->
                <Grid
                    x:Name="EpisodeExpansionPanel"
                    Visibility="{x:Bind ViewModel.EpisodesAccordionVisibility, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Linke Spalte: Episoden-Kacheln ohne Header – Header ist fixiert in Row 4 -->
                    <ctrl:EpisodeAccordionControl
                        x:Name="EpisodeAccordion"
                        Grid.Column="0"
                        EpisodesSource="{x:Bind ViewModel.Episodes, Mode=OneWay}"
                        SelectionMode="Single">
                        <ctrl:EpisodeAccordionControl.EpisodeTemplate>
                            <DataTemplate x:DataType="vm:LocalEpisodeCardViewModel">
                                <ctrl:EpisodeTileControl
                                    CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                    Title="{x:Bind Title, Mode=OneTime}"
                                    StatusTextValue="{x:Bind EpisodeNumberText, Mode=OneTime}"
                                    CompletedVisibility="{x:Bind CompletedCheckVisibility, Mode=OneWay}"
                                    ActionGlyph="&#xE712;">
                                    <ctrl:EpisodeTileControl.ActionFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Uid="LokalEpisodeMarkPlayedItem"
                                                            Tag="{x:Bind EpisodeId, Mode=OneTime}"
                                                            Click="OnEpisodeMarkPlayedClick"/>
                                            <MenuFlyoutItem x:Uid="LokalEpisodeMarkUnplayedItem"
                                                            Tag="{x:Bind EpisodeId, Mode=OneTime}"
                                                            Click="OnEpisodeMarkUnplayedClick"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem x:Uid="LokalEpisodeCoverSelectItem"
                                                            Tag="{x:Bind EpisodeId, Mode=OneTime}"
                                                            Click="OnEpisodeCoverSelectClick"/>
                                            <MenuFlyoutItem x:Uid="LokalEpisodeCoverSearchItem"
                                                            Tag="{x:Bind EpisodeId, Mode=OneTime}"
                                                            Click="OnEpisodeCoverSearchClick"/>
                                        </MenuFlyout>
                                    </ctrl:EpisodeTileControl.ActionFlyout>
                                </ctrl:EpisodeTileControl>
                            </DataTemplate>
                        </ctrl:EpisodeAccordionControl.EpisodeTemplate>
                    </ctrl:EpisodeAccordionControl>

                    <!-- Rechte Spalte: Track-Panel (nur wenn Folge ausgewählt) -->
                    <Grid
                        Grid.Column="1"
                        Width="300"
                        Visibility="{x:Bind ViewModel.TracksAccordionVisibility, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Track-Kopfzeile mit Folgenname und Aktions-Buttons -->
                        <Grid Grid.Row="0" Padding="8,8,8,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Metadaten: Folgennummer · Trackanzahl · Gesamtspielzeit -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Text="{x:Bind ViewModel.TrackPanelSubtitle, Mode=OneWay}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Margin="0,0,0,2"/>

                            <!-- Folgentitel als Überschrift -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="{x:Bind ViewModel.SelectedEpisodeTitle, Mode=OneWay}"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center"/>

                            <!-- Folge abspielen -->
                            <Button
                                Grid.Row="1"
                                Grid.Column="1"
                                x:Uid="LokalPlayEpisodeButton"
                                Command="{x:Bind ViewModel.PlayEpisodeCommand}"
                                Visibility="{x:Bind ViewModel.TrackActionsVisibility, Mode=OneWay}">
                                <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            </Button>

                            <!-- Tracks im Tag-Manager bearbeiten -->
                            <Button
                                Grid.Row="1"
                                Grid.Column="2"
                                ToolTipService.ToolTip="Alle Tracks dieser Folge im Tag-Manager bearbeiten"
                                Command="{x:Bind ViewModel.OpenAllEpisodeTracksCommand}"
                                Visibility="{x:Bind ViewModel.TrackActionsVisibility, Mode=OneWay}">
                                <FontIcon Glyph="&#xE8EC;" FontSize="14"/>
                            </Button>
                        </Grid>

                        <!-- Leer-Hinweis für Tracks -->
                        <TextBlock
                            Grid.Row="1"
                            x:Uid="LokalTracksEmpty"
                            Visibility="{x:Bind ViewModel.TracksEmptyVisibility, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="8,16,8,0"
                            TextWrapping="Wrap"/>

                        <!-- Track-Liste -->
                        <ListView
                            Grid.Row="1"
                            ItemsSource="{x:Bind ViewModel.Tracks, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LocalTrackRowViewModel">
                                    <Grid Padding="0,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind TrackNumber, Mode=OneTime}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"/>
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind FileName, Mode=OneTime}"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind FilePath, Mode=OneTime}"/>
                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{x:Bind DurationText, Mode=OneTime}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"/>
                                        <Button
                                            Grid.Column="3"
                                            ToolTipService.ToolTip="Im Tag-Manager öffnen"
                                            Command="{x:Bind OpenInTagManagerCommand}"
                                            Padding="4">
                                            <FontIcon Glyph="&#xEBBE;" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <!-- Serien – unterer Teil (Kacheln nach der ausgewählten Reihe) -->
                <GridView
                    x:Name="SeriesBottomGrid"
                    SelectionMode="Single"
                    SelectionChanged="OnArtistSelectionChanged"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" ItemWidth="148" ItemHeight="166"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <!-- Gleiche Kachel wie SeriesTopGrid – UserControl statt dupliziertem DataTemplate -->
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LocalArtistCardViewModel">
                            <ctrl:SeriesTileControl
                                CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                Title="{x:Bind Title, Mode=OneTime}"
                                Subtitle="{x:Bind CountText, Mode=OneTime}">
                                <ctrl:SeriesTileControl.ContextFlyoutMenu>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Uid="SeriesDetailsItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesDetailsClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE946;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <ToggleMenuFlyoutItem
                                            x:Uid="WatchSeriesItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            IsChecked="{x:Bind IsWatched, Mode=OneWay}"
                                            Click="OnToggleWatchSeriesClick">
                                            <ToggleMenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE7B3;"/>
                                            </ToggleMenuFlyoutItem.Icon>
                                        </ToggleMenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalMarkAllAsReadItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnMarkAllAsReadClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalMissingEpisodesItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnShowMissingEpisodesClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalRemoveFromLibraryItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnRemoveSeriesFromLibraryClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalDeleteFromDiskItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnDeleteSeriesFromDiskClick"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalSeriesCoverSelectItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesCoverSelectClick"/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalSeriesCoverSearchItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnSeriesCoverSearchClick"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem
                                            x:Uid="LokalRestructureItem"
                                            Tag="{x:Bind SeriesId, Mode=OneTime}"
                                            Click="OnRestructureClick"/>
                                    </MenuFlyout>
                                </ctrl:SeriesTileControl.ContextFlyoutMenu>
                            </ctrl:SeriesTileControl>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

            </StackPanel>
        </ScrollViewer>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipLokal"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>

</Page>
