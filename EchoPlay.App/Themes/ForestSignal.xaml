<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- ForestSignal ist ein dunkles Theme – beide Dictionaries zeigen dieselbe Palette.
             RequestedTheme wird vom ThemeService auf Dark gesetzt. -->

        <!-- Light-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht.
             ForestSignal ist ein fixes Dunkles Theme – identische Werte wie Dark. -->
        <ResourceDictionary x:Key="Light">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#0F1A14"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#16241C"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#16241C"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#0F1A14"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#1E2F25"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#1E2F25"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#16241C"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#E6F2EC"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#9FB7AA"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#8FA49A"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#6F8F80"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#1E2F25"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#22352B"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#3FA37A"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#52B88E"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#2F7D5D"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                   Color="#0F1A14"/>
            <SolidColorBrush x:Key="SurfaceBrush"                         Color="#0F1A14"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                 Color="#16241C"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                    Color="#1E2F25"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                     Color="#E6F2EC"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                   Color="#9FB7AA"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                    Color="#8FA49A"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                    Color="#6F8F80"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                   Color="#3FA37A"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"              Color="#52B88E"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"            Color="#2F7D5D"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"           Color="#1C4A38"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                Color="#3FA37A"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"           Color="#52B88E"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"         Color="#2F7D5D"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"        Color="#182B22"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                  Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"             Color="#1E2F25"/>
            <SolidColorBrush x:Key="CardBorderBrush"                      Color="#22352B"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                 Color="#16241C"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"            Color="#1A2920"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"            Color="#16241C"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"         Color="#111F17"/>
            <SolidColorBrush x:Key="InputBorderBrush"                     Color="#22352B"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                Color="#2D4A39"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                Color="#3FA37A"/>
            <SolidColorBrush x:Key="HighlightBrush"                       Color="#1E4A3A"/>
            <SolidColorBrush x:Key="ActiveBrush"                          Color="#3FA37A"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                Color="#152E23"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"             Color="#152E23"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                 Color="#3FA37A"/>
            <FontFamily x:Key="ThemeFontFamily">Noto Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Fira Code</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Noto Sans</FontFamily>

        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">

            <!-- WinUI 3-Ressourcen überschreiben -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#0F1A14"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#16241C"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#16241C"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#0F1A14"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#1E2F25"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#1E2F25"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#16241C"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#E6F2EC"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#9FB7AA"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#8FA49A"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#6F8F80"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#1E2F25"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#22352B"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#3FA37A"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#52B88E"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#2F7D5D"/>

            <!-- Background / Surfaces -->
            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="#0F1A14"/>
            <SolidColorBrush x:Key="SurfaceBrush"           Color="#0F1A14"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="#16241C"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"      Color="#1E2F25"/>

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#E6F2EC"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FB7AA"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#8FA49A"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#6F8F80"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Accent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#3FA37A"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#52B88E"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#2F7D5D"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#1C4A38"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#3FA37A"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#52B88E"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#2F7D5D"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#182B22"/>

            <!-- Cards -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#16241C"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#1E2F25"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#22352B"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#16241C"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#1A2920"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#16241C"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#111F17"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#22352B"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#2D4A39"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#3FA37A"/>

            <!-- Selection / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#1E4A3A"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#3FA37A"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#152E23"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#152E23"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#3FA37A"/>

            <!-- Typografie: Noto Sans (ruhig, natürlich, reduziert) -->
            <!-- Download: https://fonts.google.com/specimen/Noto+Sans -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">Noto Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Fira Code</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Noto Sans</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
