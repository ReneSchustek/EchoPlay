<Project>
  <!--
    Zentrale Build-Konfiguration für alle Projekte in dieser Solution.
    Einzelne .csproj-Dateien k��nnen diese Werte überschreiben.
  -->
  <PropertyGroup>
    <!-- Nullability: Null-Reference-Warnungen als Fehler -->
    <Nullable>enable</Nullable>
    <!-- Moderne using-Direktiven automatisch -->
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Alle Warnungen sind Fehler -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <!-- Alle Analyzer-Regeln aktiv (Zero-Warnings-Regel) -->
    <AnalysisMode>All</AnalysisMode>
    <!-- Code-Style in Build erzwingen -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!-- XML-Dokumentation generieren (für IntelliSense) -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Test-Projekte: xUnit-Konventionen (Unterstriche in Testnamen) -->
  <PropertyGroup Condition="$(MSBuildProjectName.EndsWith('.Tests')) or '$(MSBuildProjectName)' == 'EchoPlay.Fuzz'">
    <NoWarn>$(NoWarn);CA1707</NoWarn>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>


  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <!-- Build-Härtung: Reproduzierbarkeit und CI-Stempel.
       Deterministic stellt sicher, dass identischer Source identische Bytes erzeugt;
       ContinuousIntegrationBuild blendet maschinenspezifische Pfade aus PDBs aus. -->
  <PropertyGroup>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true' or '$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- Statische Sicherheits-Analyse für Produktiv-Code (nicht für Tests).
       SecurityCodeScan ergänzt die NetAnalyzer-Default-Regeln um Patterns wie
       weak Random, Path-Traversal, ungeprüfte Deserialisierung. -->
  <ItemGroup Condition="!$(MSBuildProjectName.EndsWith('.Tests'))">
    <PackageReference Include="SecurityCodeScan.VS2019" Version="5.6.7">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
