<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Pages.MediathekOnlinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels"
    xmlns:ctrl="using:EchoPlay.App.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hilfe -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                Grid.Row="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,4,16,0" Background="Transparent" Padding="6">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Such- und Filterleiste -->
        <Grid Grid.Row="1" Padding="16,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="0"
                x:Uid="SeriesSearchBox"
                QueryIcon="Find"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                Width="300"
                QuerySubmitted="OnProviderSearchSubmitted"/>

            <!-- Beim Anbieter suchen – nur Icon, Tooltip erklärt die Funktion -->
            <Button
                Grid.Column="1"
                x:Uid="OnlineProviderSearchButton"
                Command="{x:Bind ViewModel.ProviderSearchCommand}"
                Padding="8">
                <FontIcon Glyph="&#xE721;" FontSize="14"/>
            </Button>

            <!-- Ausgewählte Suchergebnisse importieren -->
            <Button
                Grid.Column="2"
                x:Uid="OnlineAddSelectedButton"
                Command="{x:Bind ViewModel.AddSelectedCommand}"
                Visibility="{x:Bind ViewModel.ProviderSearchResultsVisibility, Mode=OneWay}"
                Padding="8">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
            </Button>

            <!-- Suchtyp-Filter: nur sichtbar bei Provider-Suchergebnissen -->
            <ComboBox
                Grid.Column="3"
                SelectedIndex="{x:Bind ViewModel.SearchTypeIndex, Mode=TwoWay}"
                Width="120"
                Visibility="{x:Bind ViewModel.SearchTypeFilterVisibility, Mode=OneWay}">
                <ComboBoxItem x:Uid="OnlineSearchTypeAll"/>
                <ComboBoxItem x:Uid="OnlineSearchTypeSeries"/>
                <ComboBoxItem x:Uid="OnlineSearchTypeEpisodes"/>
            </ComboBox>

            <!-- Serien-Sortierung: nur sichtbar in der Bibliothek -->
            <ComboBox
                Grid.Column="3"
                SelectedIndex="{x:Bind ViewModel.SeriesSortIndex, Mode=TwoWay}"
                Width="150"
                Visibility="{x:Bind ViewModel.StatusFilterVisibility, Mode=OneWay}">
                <ComboBoxItem x:Uid="OnlineSortByName"/>
                <ComboBoxItem x:Uid="OnlineSortByEpisodeCount"/>
                <ComboBoxItem x:Uid="OnlineSortByProgress"/>
            </ComboBox>

            <!-- Aktualisieren – prüft alle Serien auf neue Folgen beim Provider -->
            <Button
                Grid.Column="5"
                x:Uid="OnlineRefreshButton"
                Command="{x:Bind ViewModel.RefreshCommand}"
                Padding="8"
                Visibility="{x:Bind ViewModel.StatusFilterVisibility, Mode=OneWay}">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>

            <!-- Statusfilter: nur sichtbar in der Bibliothek -->
            <ComboBox
                Grid.Column="6"
                x:Name="StatusFilterComboBox"
                SelectionChanged="OnStatusFilterChanged"
                Width="140"
                Visibility="{x:Bind ViewModel.StatusFilterVisibility, Mode=OneWay}">
                <ComboBoxItem x:Uid="FilterAlle" IsSelected="True"/>
                <ComboBoxItem x:Uid="FilterNeu"/>
                <ComboBoxItem x:Uid="FilterInArbeit"/>
                <ComboBoxItem x:Uid="FilterGehoert"/>
            </ComboBox>
        </Grid>

        <!-- Leer-Zustand -->
        <StackPanel
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16" Padding="32">

            <StackPanel
                Visibility="{x:Bind ViewModel.NoProviderVisibility, Mode=OneWay}"
                Spacing="12" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE783;" FontSize="48" HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Uid="OnlineNoProviderHint" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="400"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:Uid="OnlineGoToSettingsButton" HorizontalAlignment="Center"
                        Click="OnGoToSettingsClick"/>
            </StackPanel>

            <StackPanel
                Visibility="{x:Bind ViewModel.NoSeriesVisibility, Mode=OneWay}"
                Spacing="12" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE8F1;" FontSize="48" HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Uid="OnlineNoSeriesHint" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="400"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button x:Uid="OnlineSearchSeriesButton" HorizontalAlignment="Center"
                        Click="OnAddSeriesClick"/>
            </StackPanel>
        </StackPanel>

        <!-- Provider-Suchergebnisse – Layout 1:1 wie Serien-Kacheln -->
        <GridView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.ProviderSearchResults, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.ProviderSearchResultsVisibility, Mode=OneWay}"
            Padding="16"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="148" ItemHeight="148"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:SearchResultViewModel">
                    <Grid Width="140" Height="140" Margin="4" CornerRadius="4">
                        <Grid.Clip>
                            <RectangleGeometry Rect="0,0,140,140"/>
                        </Grid.Clip>
                        <Image Source="{x:Bind CoverImage, Mode=OneWay}" Stretch="UniformToFill"/>
                        <!-- Platzhalter wenn kein Cover -->
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Visibility="{x:Bind NoCoverVisibility, Mode=OneWay}">
                            <FontIcon
                                Glyph="&#xE8D6;"
                                FontSize="48"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <!-- Text-Overlay unten -->
                        <Border
                            VerticalAlignment="Bottom"
                            Background="#AA000000"
                            CornerRadius="0,0,4,4"
                            Padding="6,4">
                            <StackPanel>
                                <TextBlock
                                    Text="{x:Bind Title, Mode=OneTime}"
                                    Foreground="White"
                                    FontSize="12"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis"/>
                                <TextBlock
                                    Text="{x:Bind SourceLabel, Mode=OneTime}"
                                    Foreground="#BBFFFFFF"
                                    FontSize="10"/>
                            </StackPanel>
                        </Border>
                        <!-- Checkbox oben links – weiß auf dunklem Cover.
                             Lightweight Styling: lokale Theme-Overrides für die Checkbox-Umrandung -->
                        <CheckBox
                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                            Visibility="{x:Bind LightBorderVisibility, Mode=OneWay}"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="4,4,0,0"
                            MinWidth="0" MinHeight="0">
                            <CheckBox.Resources>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="White"/>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" Color="White"/>
                            </CheckBox.Resources>
                        </CheckBox>
                        <!-- Checkbox oben links – schwarz auf hellem Cover -->
                        <CheckBox
                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                            Visibility="{x:Bind DarkBorderVisibility, Mode=OneWay}"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="4,4,0,0"
                            MinWidth="0" MinHeight="0">
                            <CheckBox.Resources>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="Black"/>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="Black"/>
                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPressed" Color="Black"/>
                            </CheckBox.Resources>
                        </CheckBox>
                        <!-- Lade-Indikator während des Imports -->
                        <ProgressRing Width="24" Height="24"
                                      IsActive="{x:Bind IsImporting, Mode=OneWay}"
                                      Visibility="{x:Bind IsImporting, Mode=OneWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Gehört-Häkchen nach Import -->
                        <FontIcon Glyph="&#xE73E;" FontSize="24"
                                  Foreground="LimeGreen"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{x:Bind AlreadyImportedVisibility, Mode=OneWay}"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Such-Ladeindikator -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsSearchingProvider, Mode=OneWay}"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <!-- Bibliothek: Akkordeon-Layout (sichtbar wenn keine Suchergebnisse) -->
        <ScrollViewer
            Grid.Row="2"
            Visibility="{x:Bind ViewModel.LibraryVisibility, Mode=OneWay}"
            VerticalScrollBarVisibility="Auto">

            <StackPanel>
                <!-- Serien-Grid OBEN (vor dem Akkordeon) -->
                <GridView
                    x:Name="SeriesTopGrid"
                    IsItemClickEnabled="True"
                    ItemClick="OnSeriesItemClick"
                    SelectionMode="Single"
                    Padding="16,16,16,0"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" ItemWidth="148" ItemHeight="166"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SeriesCardViewModel">
                            <ctrl:SeriesTileControl
                                CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                Title="{x:Bind Title, Mode=OneTime}"
                                Subtitle="{x:Bind CountText, Mode=OneTime}"
                                FavoriteVisibility="Visible"
                                FavoriteGlyph="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                FavoriteCommand="{x:Bind ToggleFavoriteCommand}"
                                WatchedVisibility="{x:Bind WatchedVisibility, Mode=OneWay}"
                                WatchedGlyph="{x:Bind WatchedGlyph, Mode=OneTime}"
                                SelectedIndicatorVisibility="{x:Bind SelectedIndicatorVisibility, Mode=OneWay}">
                                <ctrl:SeriesTileControl.ContextFlyoutMenu>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="SeriesDetailsItem"
                                                        Tag="{x:Bind Id, Mode=OneTime}"
                                                        Click="OnSeriesDetailsClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE946;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <ToggleMenuFlyoutItem
                                            x:Uid="WatchSeriesItem"
                                            Tag="{x:Bind Id, Mode=OneTime}"
                                            IsChecked="{x:Bind IsWatched, Mode=OneWay}"
                                            Click="OnToggleWatchSeriesClick">
                                            <ToggleMenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE7B3;"/>
                                            </ToggleMenuFlyoutItem.Icon>
                                        </ToggleMenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="OnlineRemoveSeriesItem"
                                                        Tag="{x:Bind Id, Mode=OneTime}"
                                                        Click="OnRemoveOnlineSeriesClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </ctrl:SeriesTileControl.ContextFlyoutMenu>
                            </ctrl:SeriesTileControl>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- Lade-Indikator für Episoden -->
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoadingEpisodes, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoadingEpisodes, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0"/>

                <!-- Lade-Indikator: sichtbar solange Episoden geladen werden -->
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoadingEpisodes, Mode=OneWay}"
                    Width="24" Height="24"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,0"
                    Visibility="{x:Bind ViewModel.LoadingEpisodesVisibility, Mode=OneWay}"/>

                <!-- Akkordeon: Folgen-Bereich – wiederverwendbares Control -->
                <ctrl:EpisodeAccordionControl
                    x:Name="EpisodeExpansionPanel"
                    Margin="16,0,0,0"
                    Visibility="{x:Bind ViewModel.EpisodesAccordionVisibility, Mode=OneWay}"
                    EpisodesSource="{x:Bind ViewModel.Episodes, Mode=OneWay}">
                    <ctrl:EpisodeAccordionControl.HeaderContent>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock x:Uid="OnlineEpisodesHeader"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                <Button Click="OnCloseEpisodePanelClick"
                                        x:Uid="OnlineCloseEpisodesButton"
                                        Background="Transparent" BorderThickness="0" Padding="4"
                                        VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                </Button>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      SelectedIndex="{x:Bind ViewModel.EpisodeSortIndex, Mode=TwoWay}"
                                      MinWidth="160">
                                <ComboBoxItem x:Uid="OnlineEpisodeSortByTitle"/>
                                <ComboBoxItem x:Uid="OnlineEpisodeSortByTitleDesc"/>
                                <ComboBoxItem x:Uid="OnlineEpisodeSortByDate"/>
                            </ComboBox>
                        </Grid>
                    </ctrl:EpisodeAccordionControl.HeaderContent>
                    <ctrl:EpisodeAccordionControl.EpisodeTemplate>
                        <DataTemplate x:DataType="vm:OnlineEpisodeCardViewModel">
                            <ctrl:EpisodeTileControl
                                CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                Title="{x:Bind DisplayText, Mode=OneTime}"
                                StatusTextValue="{x:Bind ReleaseDateText, Mode=OneTime}"
                                CompletedVisibility="{x:Bind CompletedVisibility, Mode=OneWay}"
                                TileCommand="{x:Bind OpenInBrowserCommand}"
                                ActionGlyph="&#xE712;">
                                <ctrl:EpisodeTileControl.ActionFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="OnlineEpisodeOpenBrowserItem"
                                                        Command="{x:Bind OpenInBrowserCommand}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE774;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem x:Uid="OnlineEpisodeCoverSearchItem"
                                                        Tag="{x:Bind EpisodeId, Mode=OneTime}"
                                                        Click="OnOnlineEpisodeCoverSearchClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE721;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </ctrl:EpisodeTileControl.ActionFlyout>
                            </ctrl:EpisodeTileControl>
                        </DataTemplate>
                    </ctrl:EpisodeAccordionControl.EpisodeTemplate>
                </ctrl:EpisodeAccordionControl>

                <!-- Serien-Grid UNTEN (nach dem Akkordeon) -->
                <GridView
                    x:Name="SeriesBottomGrid"
                    IsItemClickEnabled="True"
                    ItemClick="OnSeriesItemClick"
                    SelectionMode="Single"
                    Padding="16,0,16,16"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" ItemWidth="148" ItemHeight="166"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SeriesCardViewModel">
                            <ctrl:SeriesTileControl
                                CoverImage="{x:Bind CoverImage, Mode=OneWay}"
                                Title="{x:Bind Title, Mode=OneTime}"
                                Subtitle="{x:Bind CountText, Mode=OneTime}"
                                FavoriteVisibility="Visible"
                                FavoriteGlyph="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                FavoriteCommand="{x:Bind ToggleFavoriteCommand}"
                                WatchedVisibility="{x:Bind WatchedVisibility, Mode=OneWay}"
                                WatchedGlyph="{x:Bind WatchedGlyph, Mode=OneTime}"
                                SelectedIndicatorVisibility="{x:Bind SelectedIndicatorVisibility, Mode=OneWay}">
                                <ctrl:SeriesTileControl.ContextFlyoutMenu>
                                    <MenuFlyout>
                                        <MenuFlyoutItem x:Uid="SeriesDetailsItem"
                                                        Tag="{x:Bind Id, Mode=OneTime}"
                                                        Click="OnSeriesDetailsClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE946;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <ToggleMenuFlyoutItem
                                            x:Uid="WatchSeriesItem"
                                            Tag="{x:Bind Id, Mode=OneTime}"
                                            IsChecked="{x:Bind IsWatched, Mode=OneWay}"
                                            Click="OnToggleWatchSeriesClick">
                                            <ToggleMenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE7B3;"/>
                                            </ToggleMenuFlyoutItem.Icon>
                                        </ToggleMenuFlyoutItem>
                                        <MenuFlyoutItem x:Uid="OnlineRemoveSeriesItem"
                                                        Tag="{x:Bind Id, Mode=OneTime}"
                                                        Click="OnRemoveOnlineSeriesClick">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </ctrl:SeriesTileControl.ContextFlyoutMenu>
                            </ctrl:SeriesTileControl>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </ScrollViewer>

        <!-- Lade-Indikator mit optionalem Statustext (z.B. beim automatischen Episoden-Nachladen) -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}">

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>

            <TextBlock
                Text="{x:Bind ViewModel.LoadingStatusText, Mode=OneWay}"
                Style="{ThemeResource BodyTextBlockStyle}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                Opacity="0.7"/>
        </StackPanel>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipOnline"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>
</Page>
