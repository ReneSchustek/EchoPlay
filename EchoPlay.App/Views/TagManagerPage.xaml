<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.TagManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels"
    xmlns:models="using:EchoPlay.App.Models">

    <Page.Resources>
        <!-- Template für MusicBrainz-Suchergebnisse im Auswahl-Dialog -->
        <DataTemplate x:Key="LookupResultTemplate" x:DataType="models:TagLookupCandidate">
            <StackPanel Padding="4,2">
                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind Artist}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                <TextBlock Text="{x:Bind Year}" Style="{ThemeResource CaptionTextBlockStyle}"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: Ordner öffnen, Fortschritt und Ladeindikator -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="16,12,16,8">
            <Button
                x:Uid="TagManagerOpenFolderButton"
                Click="OnOpenFolderClick">
                <FontIcon Glyph="&#xE838;" FontSize="16"/>
            </Button>
            <ProgressRing
                Width="20"
                Height="20"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoadingVisibility, Mode=OneWay}"/>
            <TextBlock
                Text="{x:Bind ViewModel.BatchProgressText, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.BatchProgressVisibility, Mode=OneWay}"
                VerticalAlignment="Center"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Zweispaltiges Layout: Dateiliste | Tag-Editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Linke Spalte: Dateiliste mit Mehrfachauswahl -->
            <ListView
                x:Name="FileListView"
                Grid.Column="0"
                ItemsSource="{x:Bind ViewModel.Files, Mode=OneWay}"
                SelectionMode="Extended"
                SelectionChanged="OnFileSelectionChanged"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TagFileItemViewModel">
                        <StackPanel Padding="4,2">
                            <TextBlock
                                Text="{x:Bind RelativePath}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind FilePath}"/>
                            <!-- Änderungsmarkierung – sichtbar wenn IsModified true -->
                            <TextBlock
                                x:Uid="TagManagerUnsavedMark"
                                FontSize="10"
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                Visibility="{x:Bind IsModifiedVisibility, Mode=OneWay}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Rechte Spalte: Tag-Editor -->
            <ScrollViewer x:Name="EditorScrollViewer" Grid.Column="1" Padding="16">
                <StackPanel Spacing="8">

                    <!-- Titel -->
                    <TextBlock x:Uid="TagManagerTitleLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox
                        Text="{x:Bind ViewModel.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>

                    <!-- Album -->
                    <TextBlock x:Uid="TagManagerAlbumLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox
                        Text="{x:Bind ViewModel.Album, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>

                    <!-- Künstler -->
                    <TextBlock x:Uid="TagManagerArtistLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox
                        Text="{x:Bind ViewModel.Artist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>

                    <!-- Albumkünstler -->
                    <TextBlock x:Uid="TagManagerAlbumArtistLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox
                        Text="{x:Bind ViewModel.AlbumArtist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>

                    <!-- Erscheinungsjahr und Tracknummer nebeneinander -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Uid="TagManagerYearLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <TextBox
                                Text="{x:Bind ViewModel.Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Uid="TagManagerTrackLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Grid.Column="0"
                                    Text="{x:Bind ViewModel.TrackNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="/"
                                    VerticalAlignment="Center"
                                    Margin="4,0"/>
                                <TextBox
                                    Grid.Column="2"
                                    Text="{x:Bind ViewModel.TrackCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Genre -->
                    <TextBlock x:Uid="TagManagerGenreLabel" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <TextBox
                        Text="{x:Bind ViewModel.Genre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasSelectedFile, Mode=OneWay}"/>

                    <!-- Cover -->
                    <TextBlock x:Uid="TagManagerCoverLabel" Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image
                            Source="{x:Bind ViewModel.CoverImage, Mode=OneWay}"
                            Width="80"
                            Height="80"
                            Stretch="UniformToFill"
                            Visibility="{x:Bind ViewModel.CoverVisibility, Mode=OneWay}"/>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button
                                    x:Uid="TagManagerLoadCoverButton"
                                    Command="{x:Bind ViewModel.LoadCoverCommand}">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="16"/>
                                </Button>
                                <Button
                                    x:Uid="TagManagerRemoveCoverButton"
                                    Command="{x:Bind ViewModel.RemoveCoverCommand}">
                                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                </Button>
                            </StackPanel>
                            <Button
                                x:Uid="TagManagerCoverApplyAllButton"
                                Command="{x:Bind ViewModel.ApplyCoverToAllCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="14"/>
                                    <TextBlock x:Uid="TagManagerCoverApplyAllText" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

                    <!-- Online-Lookup: manuell oder automatisch aus Ordnerkontext -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Uid="TagManagerLookupButton"
                            Command="{x:Bind ViewModel.LookupOnlineCommand}">
                            <FontIcon Glyph="&#xE774;" FontSize="16"/>
                        </Button>
                        <Button
                            x:Uid="TagManagerAutoLookupButton"
                            Command="{x:Bind ViewModel.AutoLookupCommand}">
                            <FontIcon Glyph="&#xE721;" FontSize="16"/>
                        </Button>
                        <Button
                            x:Uid="TagManagerApplyToAllButton"
                            Command="{x:Bind ViewModel.ApplyToAllCommand}"
                            Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8D3;" FontSize="14"/>
                                <TextBlock x:Uid="TagManagerApplyToAllText" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                        </Button>
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind ViewModel.IsLookingUp, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsLookingUpVisibility, Mode=OneWay}"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Bestätigung nach automatischer Tag-Übernahme -->
                    <InfoBar
                        x:Name="AutoLookupInfoBar"
                        Severity="Informational"
                        IsOpen="False"
                        IsClosable="True"/>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                    <!-- Aktionsbuttons: Speichern, Alle speichern, Alle Tags löschen -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Uid="TagManagerSaveButton"
                            Command="{x:Bind ViewModel.SaveCommand}"
                            Style="{ThemeResource AccentButtonStyle}">
                            <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                        </Button>
                        <Button
                            x:Uid="TagManagerSaveAllButton"
                            Command="{x:Bind ViewModel.SaveAllCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE78C;" FontSize="14"/>
                                <TextBlock x:Uid="TagManagerSaveAllText" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                        </Button>
                        <Button
                            x:Uid="TagManagerRemoveAllTagsButton"
                            Command="{x:Bind ViewModel.RemoveAllTagsCommand}">
                            <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

                    <!-- Umbenennung nach Muster (MP3Tag-Stil) -->
                    <TextBlock x:Name="RenameSectionLabel" x:Uid="TagManagerRenameSectionLabel" Style="{ThemeResource BodyStrongTextBlockStyle}"/>

                    <TextBlock x:Uid="TagManagerRenamePatternLabel" Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,4,0,0"/>
                    <TextBox
                        Text="{x:Bind ViewModel.RenamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        IsEnabled="{x:Bind ViewModel.HasFiles, Mode=OneWay}"
                        PlaceholderText="{x:Bind ViewModel.RenamePattern, Mode=OneWay}"/>

                    <!-- Platzhalter-Hilfe: zeigt alle unterstützten Token auf einen Blick -->
                    <TextBlock
                        x:Uid="TagManagerRenamePlaceholderHint"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button
                            x:Uid="TagManagerPreviewRenameButton"
                            Command="{x:Bind ViewModel.PreviewRenameCommand}">
                            <FontIcon Glyph="&#xE890;" FontSize="16"/>
                        </Button>
                        <Button
                            x:Uid="TagManagerExecuteRenameButton"
                            Command="{x:Bind ViewModel.ExecuteRenameCommand}"
                            Style="{ThemeResource AccentButtonStyle}">
                            <FontIcon Glyph="&#xE8AC;" FontSize="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Vorschau-Liste: nur sichtbar wenn Vorschau berechnet wurde -->
                    <ListView
                        ItemsSource="{x:Bind ViewModel.RenamePreview, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.RenamePreviewVisibility, Mode=OneWay}"
                        SelectionMode="None"
                        Margin="0,4,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:RenamePreviewDisplay">
                                <StackPanel Padding="4,2">
                                    <!-- Neuer Name prominent, alter Name als Herkunftshinweis -->
                                    <TextBlock Text="{x:Bind NewName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind OldName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
