<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Pages.SeriesDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Kopfzeile: Titel + Filter + Sortierung -->
            <RowDefinition Height="Auto"/>
            <!-- Serienbeschreibung (optional) -->
            <RowDefinition Height="Auto"/>
            <!-- Gesamtfortschritt -->
            <RowDefinition Height="Auto"/>
            <!-- Zwei-Spalten-Ansicht -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Kopfzeile -->
        <Grid Grid.Row="0" Margin="16,16,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Zurück-Pfeil -->
            <Button
                Grid.Column="0"
                Click="OnBackClick"
                Style="{ThemeResource SubtleButtonStyle}"
                Padding="8"
                Margin="0,0,8,0"
                VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
            </Button>

            <TextBlock
                Grid.Column="1"
                Text="{x:Bind ViewModel.SeriesTitle, Mode=OneWay}"
                Style="{ThemeResource TitleTextBlockStyle}"
                VerticalAlignment="Center"/>

            <!-- Favoriten-Stern: gefüllt wenn favorisiert, leer sonst.
                 Segoe Fluent: E735 = gefüllter Stern, E734 = leerer Stern -->
            <Button
                Grid.Column="2"
                x:Uid="SeriesDetailFavoriteButton"
                Content="{x:Bind ViewModel.FavoriteGlyph, Mode=OneWay}"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                FontSize="20"
                Command="{x:Bind ViewModel.ToggleFavoriteCommand}"
                Style="{ThemeResource SubtleButtonStyle}"
                Padding="8"
                Margin="8,0,4,0"
                VerticalAlignment="Center"/>

            <!-- Filter-ComboBox -->
            <ComboBox
                Grid.Column="3"
                SelectedIndex="{x:Bind ViewModel.EpisodeFilterIndex, Mode=TwoWay}"
                MinWidth="120"
                VerticalAlignment="Center">
                <ComboBoxItem x:Uid="LokalFilterAll"/>
                <ComboBoxItem x:Uid="LokalFilterUnheard"/>
                <ComboBoxItem x:Uid="LokalFilterHeard"/>
                <ComboBoxItem x:Uid="LokalFilterInProgress"/>
            </ComboBox>

            <!-- Sortier-ComboBox -->
            <ComboBox
                x:Name="SortComboBox"
                Grid.Column="4"
                SelectionChanged="OnSortOrderChanged"
                MinWidth="160"
                VerticalAlignment="Center">
                <ComboBoxItem x:Uid="SortEpisodeNumber"/>
                <ComboBoxItem x:Uid="SortTitle"/>
                <ComboBoxItem x:Uid="SortReleaseDate"/>
            </ComboBox>
        </Grid>

        <!-- Serienbeschreibung (vom Provider, z.B. Spotify) -->
        <TextBlock
            Grid.Row="1"
            Text="{x:Bind ViewModel.SeriesDescription, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.DescriptionVisibility, Mode=OneWay}"
            Style="{ThemeResource BodyTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
            MaxLines="3"
            Margin="16,0,16,8"/>

        <!-- Gesamtfortschritt -->
        <StackPanel Grid.Row="2" Margin="16,0,16,8">
            <TextBlock
                Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Margin="0,0,0,4"/>
            <ProgressBar
                Value="{x:Bind ViewModel.OverallProgressPercent, Mode=OneWay}"
                Maximum="100"
                IsIndeterminate="False"/>
        </StackPanel>

        <!-- Zwei-Spalten-Ansicht: Folgen | Tracks -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <!-- Linke Spalte: Kachelansicht der Folgen (40 %) -->
                <ColumnDefinition Width="2*"/>
                <!-- Rechte Spalte: Track-Liste der gewählten Folge (60 %) -->
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Linke Spalte: Tab-Leiste + Episodenkacheln.
                 Eigene RowDefinitions damit die Tab-Leiste nicht vom GridView verdeckt wird. -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab-Leiste: Folgen / Sonderfolgen – nur sichtbar wenn Sonderfolgen existieren -->
                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="8,0"
                    Visibility="{x:Bind ViewModel.HasSpecialEpisodes, Mode=OneWay}">
                    <RadioButton
                        x:Uid="LokalTabEpisodes"
                        GroupName="DetailEpisodeTab"
                        IsChecked="True"
                        Checked="OnDetailTabRegularChecked"/>
                    <RadioButton
                        GroupName="DetailEpisodeTab"
                        Checked="OnDetailTabSpecialChecked">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Uid="LokalTabSpecial"/>
                            <TextBlock Text="(" />
                            <TextBlock Text="{x:Bind ViewModel.SpecialEpisodeCount, Mode=OneWay}"/>
                            <TextBlock Text=")" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Kacheln + Overlays in einer eigenen Zeile -->
                <Grid Grid.Row="1">
                    <!-- Ladeindikator überlagert die Liste während des Ladens -->
                    <ProgressRing
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                    <!-- Leer-Hinweis: keine Episoden vorhanden -->
                    <TextBlock
                        x:Uid="SeriesDetailEpisodesEmpty"
                        Visibility="{x:Bind ViewModel.EpisodesEmptyVisibility, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="16"/>

                    <!-- Episodenkacheln mit Cover-Thumbnail links und Text rechts -->
                    <GridView
                        ItemsSource="{x:Bind ViewModel.Episodes, Mode=OneWay}"
                        SelectionMode="Single"
                        SelectionChanged="OnEpisodeSelectionChanged"
                        Padding="8">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EpisodeTileViewModel">
                                <Border
                                    Width="220"
                                    Height="100"
                                    CornerRadius="4"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <!-- Cover-Thumbnail -->
                                            <ColumnDefinition Width="80"/>
                                            <!-- Text-Bereich -->
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover-Bild, gerundet links -->
                                        <Grid Grid.Column="0" CornerRadius="4,0,0,4">
                                            <Grid.Clip>
                                                <RectangleGeometry Rect="0,0,80,98"/>
                                            </Grid.Clip>
                                            <Image
                                                Source="{x:Bind CoverImage}"
                                                Width="80" Height="98"
                                                Stretch="UniformToFill"/>
                                            <!-- Platzhalter-Icon wenn kein Cover vorhanden -->
                                            <FontIcon
                                                Glyph="&#xE8B9;"
                                                FontSize="24"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{x:Bind NoCoverVisibility}"/>
                                        </Grid>

                                        <!-- Text-Bereich rechts neben dem Cover -->
                                        <Grid Grid.Column="1" Padding="8,6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Kontextmenü oben rechts – überlagert den Text-Bereich -->
                                            <Button
                                                Content="&#xE712;"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                Width="24" Height="24" Padding="0"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-2,-4,0" CornerRadius="4"
                                                Background="Transparent"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem
                                                            x:Uid="DashboardMenuMarkPlayed"
                                                            Tag="{x:Bind EpisodeId}"
                                                            Click="OnEpisodeMarkPlayedClick"/>
                                                        <MenuFlyoutItem
                                                            x:Uid="DashboardMenuMarkUnplayed"
                                                            Tag="{x:Bind EpisodeId}"
                                                            Click="OnEpisodeMarkUnplayedClick"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>

                                            <TextBlock
                                                Grid.Row="0"
                                                Text="{x:Bind DisplayTitle}"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"
                                                MaxLines="3"
                                                Style="{ThemeResource BodyTextBlockStyle}"/>

                                            <!-- Untere Zeile: Haken + Dauer + Fortschrittsbalken -->
                                            <StackPanel Grid.Row="1" Spacing="3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <FontIcon
                                                        Grid.Column="0"
                                                        Glyph="&#xE73E;"
                                                        FontSize="12"
                                                        Foreground="LimeGreen"
                                                        Visibility="{x:Bind CompletedCheckVisibility}"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center"/>

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind DurationText}"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        VerticalAlignment="Center"/>
                                                </Grid>

                                                <ProgressBar
                                                    Value="{x:Bind ProgressPercent}"
                                                    Maximum="100"
                                                    IsIndeterminate="False"
                                                    Visibility="{x:Bind ProgressBarVisibility}"
                                                    Height="3"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </Grid>

            <!-- Trennlinie -->
            <Rectangle
                Grid.Column="0"
                Width="1"
                HorizontalAlignment="Right"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- Rechte Spalte: Track-Liste -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Aktionsleiste: "Ganze Folge abspielen" – nur sichtbar wenn Tracks vorhanden -->
                <Button
                    Grid.Row="0"
                    x:Uid="SeriesDetailPlayEpisodeButton"
                    Margin="8,8,8,4"
                    Click="OnPlayEpisodeClick"
                    Visibility="{x:Bind ViewModel.TrackActionsVisibility, Mode=OneWay}"/>

                <!-- Track-Liste -->
                <Grid Grid.Row="1">
                    <!-- "Folge wählen"-Hinweis -->
                    <TextBlock
                        x:Uid="SeriesDetailTracksEmpty"
                        Visibility="{x:Bind ViewModel.TracksEmptyVisibility, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="16"/>

                    <!-- "Keine lokalen Dateien"-Hinweis -->
                    <TextBlock
                        x:Uid="SeriesDetailNoLocalTracks"
                        Visibility="{x:Bind ViewModel.NoLocalTracksVisibility, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="16"/>

                    <!-- Track-Zeilen -->
                    <ListView
                        ItemsSource="{x:Bind ViewModel.Tracks, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:LocalTrackRowViewModel">
                                <Grid Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind TrackNumber}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind FileName}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center"/>

                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind DurationText}"
                                        HorizontalAlignment="Right"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</Page>
