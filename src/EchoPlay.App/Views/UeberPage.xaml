<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.UeberPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Spacing="12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="420"
            Margin="24,48,24,48">

            <!-- App-Logo (transparente Variante, ohne weißen Hintergrund) -->
            <Image
                Source="ms-appx:///Assets/logo-transparent.png"
                Width="96"
                Height="96"
                HorizontalAlignment="Center"
                Margin="0,0,0,8"/>

            <!-- App-Name -->
            <TextBlock
                Text="EchoPlay"
                Style="{ThemeResource TitleTextBlockStyle}"
                HorizontalAlignment="Center"/>

            <!-- Versionsnummer – wird im Code-Behind gesetzt -->
            <TextBlock
                x:Name="VersionText"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"/>

            <Rectangle
                Height="1"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,8"/>

            <!-- Beschreibungstext -->
            <TextBlock
                x:Uid="UeberDescription"
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="Wrap"
                TextAlignment="Center"/>

            <Rectangle
                Height="1"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,8"/>

            <!-- Entwicklerangabe -->
            <TextBlock
                x:Uid="UeberDevelopedBy"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"/>

            <TextBlock
                Text="Ruhrcoder (René Schustek)"
                Style="{ThemeResource BodyTextBlockStyle}"
                HorizontalAlignment="Center"/>

            <TextBlock
                Text="ruhrcoder.de"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"/>

            <!-- Copyright -->
            <TextBlock
                x:Uid="UeberCopyright"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"/>

            <Rectangle
                Height="1"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,16"/>

            <!-- Ordnerstruktur-Erklärung: zeigt das erwartete Layout der lokalen Bibliothek -->
            <TextBlock
                x:Uid="UeberOrdnerstrukturHeading"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                HorizontalAlignment="Left"/>

            <TextBlock
                x:Uid="UeberOrdnerstrukturText"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontFamily="Consolas"
                TextWrapping="Wrap"
                Margin="0,4,0,0"/>

            <!-- Freiwilliger Spenden-Einstieg. Bleibt ausgeblendet, solange kein echter
                 PayPal-Handle konfiguriert ist (Sichtbarkeit im Code-Behind gesetzt). -->
            <StackPanel
                x:Name="SupportPanel"
                Spacing="8"
                Visibility="Collapsed"
                Margin="0,8,0,0">

                <Rectangle
                    Height="1"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Margin="0,8"/>

                <TextBlock
                    x:Uid="UeberSupportHeading"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"/>

                <Button
                    x:Uid="SupportButton"
                    Click="OnSupportClick"
                    HorizontalAlignment="Center"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
