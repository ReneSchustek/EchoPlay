<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!--
            Ruhrcoder – industriell, direkter Kontrast, kompakt.
            Kernmerkmal: dunkle Navigations-Pane (#2F4858) gegen hellen Inhaltsbereich (#EEEEEE).
            Das erzeugt sofort das Gefühl einer zweigeteilt strukturierten Oberfläche.
            Beide Dictionaries (Light/Dark) sind identisch – Ruhrcoder ist ein festes Helles Theme,
            der ThemeService setzt RequestedTheme=Light.
        -->

        <ResourceDictionary x:Key="Light">

            <!-- ── App-Hintergrund ─────────────────────────────────────────────── -->
            <!--
                Industrielles Hellgrau – deutlich getrennt vom reinen Weiß der Karten.
                Schafft den "Arbeitsfläche hinter den Karten"-Eindruck.
            -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#EEEEEE"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                  Color="#EEEEEE"/>
            <SolidColorBrush x:Key="SurfaceBrush"                        Color="#EEEEEE"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                   Color="#E2E2E2"/>

            <!-- ── NavigationView-Pane: dunkel ────────────────────────────────── -->
            <!--
                #2F4858 ist das visuelle Herzstück: dunkle Stahlblau-Grau-Pane.
                In Kombination mit dem hellen Inhaltsbereich entsteht der "split"-Eindruck,
                ohne dass der Nutzer überhaupt eine Karte anschauen muss.
            -->
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#2F4858"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#2F4858"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#EEEEEE"/>
            <SolidColorBrush x:Key="NavigationViewPaneBorderBrush"        Color="#1E3344"/>

            <!-- Pane-Items: helles Textmaterial auf dunklem Grund -->
            <SolidColorBrush x:Key="NavigationViewItemForeground"                        Color="#B8CDD8"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed"                 Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver"     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed"         Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundDisabled"                Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedDisabled"        Color="#5A7080"/>

            <!-- Icon-Foregrounds: gleiche Logik wie Item-Foregrounds -->
            <SolidColorBrush x:Key="NavigationViewItemIconForeground"                    Color="#B8CDD8"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed"             Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelected"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPointerOver" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPressed"     Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundDisabled"            Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedDisabled"    Color="#5A7080"/>

            <!-- Item-Hintergründe im Pane -->
            <SolidColorBrush x:Key="NavigationViewItemBackground"                        Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"             Color="#3D5C6F"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"                 Color="#243A49"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"                Color="#3D5C6F"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver"     Color="#4A6B7E"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed"         Color="#243A49"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"                Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedDisabled"        Color="#2A4050"/>

            <!-- Selektion-Indicator: Akzentfarbe, gut sichtbar gegen dunklen Pane -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#4A9CC5"/>

            <!-- Header/Footer-Tasten in der Pane (Back-Button, Hamburger) -->
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed"     Color="#D8E8F0"/>

            <!-- ── WinUI-Standard-Overrides ───────────────────────────────────── -->
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"          Color="#F0F0F0"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"        Color="#FFFFFF"/>

            <!-- Text: hoher Kontrast, industriell direkt -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"   Color="#111827"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#4B5563"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"  Color="#6B7280"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"  Color="#9CA3AF"/>

            <!-- Trennlinien: sichtbar, klar -->
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#C0C0C0"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"    Color="#D1D5DB"/>

            <!-- Akzent: Stahlblau, technisch, sachlich -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#2E6DA4"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#3D83BB"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#1F5A8A"/>

            <!-- ── Eigene semantische Ressourcen ──────────────────────────────── -->

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#111827"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5563"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#6B7280"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Akzent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#2E6DA4"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#3D83BB"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#1F5A8A"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#B8D3E8"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#2E6DA4"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#3D83BB"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#1F5A8A"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#D6E6F2"/>

            <!-- Karten: weiße Fläche auf grauem Untergrund -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#C8C8C8"/>

            <!--
                Semantische Karten-Header-Ressourcen.
                Entsprechen dem Pane-Farbton – wenn Karten den Split-Stil implementieren,
                verwenden sie diese Brushes für den oberen Bereich.
            -->
            <SolidColorBrush x:Key="CardHeaderBackgroundBrush" Color="#2F4858"/>
            <SolidColorBrush x:Key="CardHeaderForegroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBodyBackgroundBrush"   Color="#F0F0F0"/>
            <SolidColorBrush x:Key="CardBodyForegroundBrush"   Color="#444444"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#F5F5F5"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#EEEEEE"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#C8C8C8"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#9AACB8"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#2E6DA4"/>

            <!-- Selektion / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#1F5A8A"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#2E6DA4"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#D6E8F5"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#D6E8F5"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#2E6DA4"/>

            <!-- Typografie: Roboto – technisch, sachlich, direkt -->
            <!-- Download: https://fonts.google.com/specimen/Roboto -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">Roboto</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Roboto Mono</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Roboto</FontFamily>

        </ResourceDictionary>

        <!--
            Dark-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht.
            Ruhrcoder ist ein fixes Helles Theme – identische Werte wie Light.
        -->
        <ResourceDictionary x:Key="Dark">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#EEEEEE"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                  Color="#EEEEEE"/>
            <SolidColorBrush x:Key="SurfaceBrush"                        Color="#EEEEEE"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                   Color="#E2E2E2"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#2F4858"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#2F4858"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#EEEEEE"/>
            <SolidColorBrush x:Key="NavigationViewPaneBorderBrush"        Color="#1E3344"/>
            <SolidColorBrush x:Key="NavigationViewItemForeground"                        Color="#B8CDD8"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed"                 Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver"     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed"         Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundDisabled"                Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedDisabled"        Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForeground"                    Color="#B8CDD8"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed"             Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelected"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPointerOver" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPressed"     Color="#D8E8F0"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundDisabled"            Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedDisabled"    Color="#5A7080"/>
            <SolidColorBrush x:Key="NavigationViewItemBackground"                        Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"             Color="#3D5C6F"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"                 Color="#243A49"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"                Color="#3D5C6F"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver"     Color="#4A6B7E"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed"         Color="#243A49"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"                Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedDisabled"        Color="#2A4050"/>
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground"          Color="#4A9CC5"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver"           Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed"               Color="#D8E8F0"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"          Color="#F0F0F0"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"        Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"             Color="#111827"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"           Color="#4B5563"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"            Color="#6B7280"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"            Color="#9CA3AF"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"        Color="#C0C0C0"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"           Color="#D1D5DB"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"           Color="#2E6DA4"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"         Color="#3D83BB"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"          Color="#1F5A8A"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                      Color="#111827"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                    Color="#4B5563"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                     Color="#6B7280"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                     Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                    Color="#2E6DA4"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"               Color="#3D83BB"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"             Color="#1F5A8A"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"            Color="#B8D3E8"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                 Color="#2E6DA4"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"            Color="#3D83BB"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"          Color="#1F5A8A"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"         Color="#D6E6F2"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"              Color="#F5F5F5"/>
            <SolidColorBrush x:Key="CardBorderBrush"                       Color="#C8C8C8"/>
            <SolidColorBrush x:Key="CardHeaderBackgroundBrush"             Color="#2F4858"/>
            <SolidColorBrush x:Key="CardHeaderForegroundBrush"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBodyBackgroundBrush"               Color="#F0F0F0"/>
            <SolidColorBrush x:Key="CardBodyForegroundBrush"               Color="#444444"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"             Color="#F5F5F5"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"          Color="#EEEEEE"/>
            <SolidColorBrush x:Key="InputBorderBrush"                      Color="#C8C8C8"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                 Color="#9AACB8"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                 Color="#2E6DA4"/>
            <SolidColorBrush x:Key="HighlightBrush"                        Color="#1F5A8A"/>
            <SolidColorBrush x:Key="ActiveBrush"                           Color="#2E6DA4"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                 Color="#D6E8F5"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"              Color="#D6E8F5"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                  Color="#2E6DA4"/>
            <FontFamily x:Key="ThemeFontFamily">Roboto</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Roboto Mono</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Roboto</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
