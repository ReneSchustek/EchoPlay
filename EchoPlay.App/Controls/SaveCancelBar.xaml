<?xml version="1.0" encoding="utf-8"?>
<!-- Wiederverwendbare Speichern/Abbrechen-Buttonleiste mit Trennlinie.
     Wird in den vier Tabs der SettingsPage verwendet. Klicks werden über
     die Events SaveClicked und CancelClicked an die aufrufende Page weitergereicht. -->
<UserControl
    x:Class="EchoPlay.App.Controls.SaveCancelBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <Rectangle Height="1"
                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                   Margin="0,12,0,0"/>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button x:Uid="SaveButton"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="OnSaveButtonClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                    <TextBlock x:Uid="SaveButtonLabel" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Uid="CancelButton"
                    Click="OnCancelButtonClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                    <TextBlock x:Uid="CancelButtonLabel" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
