<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="EchoPlay.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EchoPlay.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Alle sechs Farbpaletten sind deklariert. Aktiv ist zur Laufzeit immer nur eine –
                     ThemeService entfernt beim Start die inaktiven und tauscht sie bei Theme-Wechsel. -->
                <ResourceDictionary Source="Themes/Ruhrcoder.xaml"/>
                <ResourceDictionary Source="Themes/ModernClassic.xaml"/>
                <ResourceDictionary Source="Themes/MidnightLibrary.xaml"/>
                <ResourceDictionary Source="Themes/PaperCoffee.xaml"/>
                <ResourceDictionary Source="Themes/ForestSignal.xaml"/>
                <ResourceDictionary Source="Themes/AmberWhiskey.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
