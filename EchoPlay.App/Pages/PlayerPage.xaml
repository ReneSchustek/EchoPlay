<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Pages.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Linke Spalte: Cover + Steuerelemente -->
            <ColumnDefinition Width="320"/>
            <!-- Rechte Spalte: Playlist -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Hilfe -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Background="Transparent" Padding="6" Canvas.ZIndex="1">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- ===== LINKE SPALTE: Player-Oberfläche ===== -->
        <StackPanel Grid.Column="0" Spacing="16" Padding="24" VerticalAlignment="Top">

            <!-- Ordner/Dateien öffnen -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Uid="PlayerOpenFolderButton" Click="OnOpenFolderClick"/>
                <Button x:Uid="PlayerOpenFilesButton" Click="OnOpenFilesClick"/>
            </StackPanel>

            <!-- Coverbild: quadratisch, Platzhalter wenn kein Cover vorhanden -->
            <Border
                Width="272" Height="272"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Image
                        Source="{x:Bind ViewModel.CoverImage, Mode=OneWay}"
                        Stretch="UniformToFill"/>
                    <!-- Musik-Icon als Fallback wenn kein Cover geladen ist -->
                    <FontIcon
                        Glyph="&#xE8D6;"
                        FontSize="64"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.NoCoverVisibility, Mode=OneWay}"/>
                </Grid>
            </Border>

            <!-- Titelanzeige -->
            <TextBlock
                Text="{x:Bind ViewModel.CurrentTitle, Mode=OneWay}"
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                TextWrapping="Wrap"
                MaxLines="2"
                TextTrimming="CharacterEllipsis"
                HorizontalAlignment="Center"/>

            <!-- Positionsslider -->
            <Slider
                x:Name="PositionSlider"
                Minimum="0"
                Maximum="{x:Bind ViewModel.DurationSeconds, Mode=OneWay}"
                Value="{x:Bind ViewModel.PositionSeconds, Mode=OneWay}"
                PointerPressed="OnSliderPointerPressed"
                PointerReleased="OnSliderPointerReleased"
                HorizontalAlignment="Stretch"/>

            <!-- Zeitanzeige unter dem Slider: gespielt links am Anfang, verbleibend rechts am Ende.
                 Margin 12 px passt zum internen Padding des WinUI-3-Sliders (~10 px),
                 damit die Zeiten bündig unter den Slider-Endpunkten stehen. -->
            <Grid Margin="12,-4,12,0">
                <TextBlock
                    Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Left"/>
                <TextBlock
                    Text="{x:Bind ViewModel.RemainingOrTotalText, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Right"
                    Tapped="OnTimeDisplayTapped"/>
            </Grid>

            <!-- Wiedergabe-Steuerelemente -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                <Button
                    Content="&#xE892;"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Command="{x:Bind ViewModel.PreviousCommand}"/>

                <Button
                    Content="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Width="56" Height="56"
                    CornerRadius="28"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.PlayPauseCommand}"/>

                <Button
                    Content="&#xE893;"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Command="{x:Bind ViewModel.NextCommand}"/>
            </StackPanel>

        </StackPanel>

        <!-- ===== RECHTE SPALTE: Playlist ===== -->
        <Grid Grid.Column="1" Padding="0,24,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Playlist-Header: Episodentitel + Metadaten -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock
                    Text="{x:Bind ViewModel.PlaylistTitle, Mode=OneWay}"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="1"/>
                <TextBlock
                    Text="{x:Bind ViewModel.PlaylistSubtitle, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,2,0,0"/>
            </StackPanel>

            <ListView
                Grid.Row="1"
                x:Name="PlaylistView"
                ItemsSource="{x:Bind ViewModel.PlaylistItems, Mode=OneWay}"
                IsItemClickEnabled="True"
                ItemClick="OnPlaylistItemClick"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlaylistItemViewModel">
                        <Grid ColumnSpacing="8" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Zeilennummer oder Play-Symbol wenn aktiver Track -->
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE768;"
                                FontSize="14"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Visibility="{x:Bind IsCurrentTrackVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"/>

                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind DisplayIndex}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{x:Bind NotCurrentTrackVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"/>

                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipPlayer"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>

</Page>
