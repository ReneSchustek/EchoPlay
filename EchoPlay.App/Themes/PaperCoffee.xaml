<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- PaperCoffee ist ein helles Theme – beide Dictionaries zeigen dieselbe Palette.
             RequestedTheme wird vom ThemeService auf Light gesetzt. -->

        <ResourceDictionary x:Key="Light">

            <!-- WinUI 3-Ressourcen überschreiben -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FFFBF2"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#FCF5E5"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#FCF5E5"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#FFFBF2"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F3EBDD"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#F3EBDD"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#FCF5E5"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#4A3F35"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#7A6F63"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#9B9085"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#C2B8AE"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#D8C9BA"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#E6DCCD"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#A06040"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#B87455"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#8C5036"/>

            <!-- Background / Surfaces -->
            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="#FFFBF2"/>
            <SolidColorBrush x:Key="SurfaceBrush"           Color="#FFFBF2"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="#FCF5E5"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"      Color="#F3EBDD"/>

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#4A3F35"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7A6F63"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#9B9085"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#C2B8AE"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Accent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#A06040"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#B87455"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#8C5036"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#E6D5C8"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#A06040"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#B87455"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#8C5036"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#EADFD6"/>

            <!-- Cards -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#F3EBDD"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#E6DCCD"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#FCF5E5"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#F3EBDD"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#FCF5E5"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#F0E6DA"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#D8C9BA"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#C9B8A7"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#A06040"/>

            <!-- Selection / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#606C38"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#A06040"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#EFE3D6"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#EFE3D6"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#A06040"/>

            <!-- Typografie: IBM Plex Sans (warm, analog, leichtes Buch-Gefühl) -->
            <!-- Download: https://fonts.google.com/specimen/IBM+Plex+Sans -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">IBM Plex Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">IBM Plex Mono</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">IBM Plex Sans</FontFamily>

        </ResourceDictionary>

        <!-- Dark-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht.
             PaperCoffee ist ein fixes Helles Theme – identische Werte wie Light. -->
        <ResourceDictionary x:Key="Dark">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FFFBF2"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#FCF5E5"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#FCF5E5"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#FFFBF2"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F3EBDD"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#F3EBDD"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#FCF5E5"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#4A3F35"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#7A6F63"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#9B9085"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#C2B8AE"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#D8C9BA"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#E6DCCD"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#A06040"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#B87455"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#8C5036"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                   Color="#FFFBF2"/>
            <SolidColorBrush x:Key="SurfaceBrush"                         Color="#FFFBF2"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                 Color="#FCF5E5"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                    Color="#F3EBDD"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                     Color="#4A3F35"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                   Color="#7A6F63"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                    Color="#9B9085"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                    Color="#C2B8AE"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                   Color="#A06040"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"              Color="#B87455"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"            Color="#8C5036"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"           Color="#E6D5C8"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                Color="#A06040"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"           Color="#B87455"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"         Color="#8C5036"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"        Color="#EADFD6"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                  Color="#FCF5E5"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"             Color="#F3EBDD"/>
            <SolidColorBrush x:Key="CardBorderBrush"                      Color="#E6DCCD"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                 Color="#FCF5E5"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"            Color="#F3EBDD"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"            Color="#FCF5E5"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"         Color="#F0E6DA"/>
            <SolidColorBrush x:Key="InputBorderBrush"                     Color="#D8C9BA"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                Color="#C9B8A7"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                Color="#A06040"/>
            <SolidColorBrush x:Key="HighlightBrush"                       Color="#606C38"/>
            <SolidColorBrush x:Key="ActiveBrush"                          Color="#A06040"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                Color="#EFE3D6"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"             Color="#EFE3D6"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                 Color="#A06040"/>
            <FontFamily x:Key="ThemeFontFamily">IBM Plex Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">IBM Plex Mono</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">IBM Plex Sans</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
