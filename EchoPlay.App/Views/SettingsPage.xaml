<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:EchoPlay.App.Models"
    xmlns:vm="using:EchoPlay.App.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hilfe -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                Grid.Row="0"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Margin="0,4,16,0" Background="Transparent" Padding="6">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Ladeindikator überlagert den Inhalt beim initialen Laden -->
        <ProgressRing
            Grid.RowSpan="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Canvas.ZIndex="1"/>

        <TabView
            Grid.Row="1"
            IsAddTabButtonVisible="False"
            TabWidthMode="Equal">

            <!-- ── Tab 1: Allgemein – Theme, Sprache, Log-Aufbewahrung ──────── -->
            <TabViewItem x:Uid="TabAllgemein" IsClosable="False">
                <ScrollViewer Padding="24,16,24,32">
                    <StackPanel Spacing="12">

                        <TextBlock
                            x:Uid="SettingsHeadingAppearance"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,0,0,4"/>

                        <!-- Theme-Kacheln: Farbvorschau aus ThemePreviewViewModel.All -->
                        <GridView
                            x:Name="ThemeGridView"
                            ItemsSource="{x:Bind ThemeOptions}"
                            SelectionMode="Single"
                            SelectionChanged="OnThemeSelectionChanged"
                            IsItemClickEnabled="False">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="140" ItemHeight="100"/>
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ThemePreviewViewModel">
                                    <StackPanel Spacing="4" Padding="4">
                                        <Grid Height="48" CornerRadius="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="{x:Bind BackgroundHex}" RadiusX="4" RadiusY="4"/>
                                            <Rectangle Grid.Column="1" Fill="{x:Bind PaneHex}"/>
                                            <Rectangle Grid.Column="2" Fill="{x:Bind AccentHex}" RadiusX="4" RadiusY="4"/>
                                        </Grid>
                                        <TextBlock
                                            Text="{x:Bind DisplayName}"
                                            HorizontalAlignment="Center"
                                            Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <TextBlock
                            x:Uid="SettingsHeadingLanguage"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"/>

                        <ComboBox
                            x:Name="LanguageComboBox"
                            ItemsSource="{x:Bind ViewModel.AvailableLanguages, Mode=OneTime}"
                            DisplayMemberPath="DisplayName"
                            MinWidth="200"/>

                        <Button
                            x:Uid="LanguageApplyButton"
                            Margin="0,4,0,0"
                            Click="OnLanguageApplyClick">
                            <FontIcon Glyph="&#xE73E;" FontSize="16"/>
                        </Button>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <!-- Log-Aufbewahrung hier, weil sie eine globale Einstellung ist
                             und nicht zum reinen Log-Viewer-Tab gehört -->
                        <TextBlock
                            x:Uid="SettingsHeadingLogRetention"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"/>

                        <NumberBox
                            x:Uid="LogRetentionDaysBox"
                            Value="{x:Bind ViewModel.LogRetentionDays, Mode=OneWay}"
                            Minimum="1"
                            Maximum="365"
                            SpinButtonPlacementMode="Inline"
                            SmallChange="1"
                            Width="160"
                            HorizontalAlignment="Left"
                            ValueChanged="OnLogRetentionDaysChanged"/>

                        <TextBlock
                            x:Uid="SettingsHeadingLogLevel"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"/>

                        <!-- LogLevel steuert, welche Einträge in Datei und Live-Puffer landen.
                             Die Änderung gilt sofort nach dem Speichern – kein Neustart nötig. -->
                        <ComboBox
                            x:Uid="MinimumLogLevelComboBox"
                            SelectedIndex="{x:Bind ViewModel.MinimumLogLevelIndex, Mode=TwoWay}"
                            Width="200"
                            HorizontalAlignment="Left">
                            <ComboBoxItem x:Uid="LogLevelTrace"/>
                            <ComboBoxItem x:Uid="LogLevelDebug"/>
                            <ComboBoxItem x:Uid="LogLevelInformation"/>
                            <ComboBoxItem x:Uid="LogLevelWarningMin"/>
                            <ComboBoxItem x:Uid="LogLevelErrorMin"/>
                        </ComboBox>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <!-- Neuerscheinungen-Zeitraum: bestimmt wie weit zurück iTunes-Alben
                             als Neuerscheinung auf dem Dashboard angezeigt werden -->
                        <TextBlock
                            x:Uid="SettingsHeadingNewReleaseDays"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"/>

                        <NumberBox
                            x:Uid="NewReleaseDaysBox"
                            Value="{x:Bind ViewModel.NewReleaseDays, Mode=OneWay}"
                            Minimum="7"
                            Maximum="365"
                            SpinButtonPlacementMode="Inline"
                            SmallChange="1"
                            Width="160"
                            HorizontalAlignment="Left"
                            ValueChanged="OnNewReleaseDaysChanged"/>

                        <!-- Offline-Modus: deaktiviert iTunes-Abfragen, Suche und Neuerscheinungen -->
                        <ToggleSwitch
                            x:Uid="SettingsOfflineMode"
                            IsOn="{x:Bind ViewModel.OfflineMode, Mode=TwoWay}"
                            Margin="0,16,0,0"/>

                        <!-- Nur-Online-Modus: blendet die lokale Mediathek aus -->
                        <ToggleSwitch
                            x:Uid="SettingsOnlineOnlyMode"
                            IsOn="{x:Bind ViewModel.OnlineOnlyMode, Mode=TwoWay}"
                            Margin="0,8,0,0"/>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button
                                x:Uid="SaveButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OnSaveClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock x:Uid="SaveButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button
                                x:Uid="CancelButton"
                                Click="OnCancelClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                    <TextBlock x:Uid="CancelButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Tab 2: Online – Provider-Auswahl + Verbindungstest ────────── -->
            <TabViewItem x:Uid="TabOnline" IsClosable="False">
                <ScrollViewer Padding="24,16,24,32">
                    <StackPanel Spacing="12">

                        <TextBlock
                            x:Uid="SettingsHeadingProvider"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,0,0,4"/>

                        <RadioButton
                            x:Name="RadioSpotify"
                            Content="Spotify"
                            GroupName="Provider"
                            Tag="Spotify"
                            Checked="OnProviderChecked"/>
                        <RadioButton
                            x:Name="RadioAppleMusic"
                            Content="Apple Music"
                            GroupName="Provider"
                            Tag="AppleMusic"
                            Checked="OnProviderChecked"/>
                        <RadioButton
                            x:Name="RadioNone"
                            x:Uid="RadioProviderNone"
                            GroupName="Provider"
                            Tag="None"
                            Checked="OnProviderChecked"/>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <!-- Verbindungstest: bei "Keine" deaktiviert, da kein Dienst konfiguriert ist -->
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                            <Button
                                x:Uid="TestConnectionButton"
                                Command="{x:Bind ViewModel.TestConnectionCommand}">
                                <FontIcon Glyph="&#xE703;" FontSize="16"/>
                            </Button>
                            <ProgressRing
                                IsActive="{x:Bind ViewModel.IsTestingConnection, Mode=OneWay}"
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Ergebnisanzeige – erst sichtbar nach dem ersten Test -->
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.ConnectionTestResultVisibility, Mode=OneWay}">
                            <FontIcon
                                Glyph="&#xE73E;"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.ConnectionTestSuccessVisibility, Mode=OneWay}"/>
                            <FontIcon
                                Glyph="&#xE711;"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.ConnectionTestFailureVisibility, Mode=OneWay}"/>
                            <TextBlock
                                Text="{x:Bind ViewModel.ConnectionTestResultText, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Style="{ThemeResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button
                                x:Uid="SaveButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OnSaveClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock x:Uid="SaveButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button
                                x:Uid="CancelButton"
                                Click="OnCancelClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                    <TextBlock x:Uid="CancelButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Tab 3: Lokal – Bibliothekspfad, Muster, Sync, DB-Pflege ──── -->
            <TabViewItem x:Uid="TabLokal" IsClosable="False">
                <ScrollViewer Padding="24,16,24,32">
                    <StackPanel Spacing="12">

                        <TextBlock
                            x:Uid="SettingsHeadingLocalLibrary"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,0,0,4"/>

                        <ToggleSwitch
                            x:Uid="LocalLibraryToggle"
                            IsOn="{x:Bind ViewModel.LocalLibraryEnabled, Mode=TwoWay}"/>

                        <ToggleSwitch
                            x:Uid="AutoImportAfterScanToggle"
                            IsOn="{x:Bind ViewModel.AutoImportAfterScan, Mode=TwoWay}"/>

                        <!-- Pfad + Durchsuchen + Sync direkt nebeneinander:
                             Sync macht nur im Kontext des Pfades Sinn -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Uid="LibraryPathTextBox"
                                Grid.Column="0"
                                Text="{x:Bind ViewModel.LocalLibraryRootPath, Mode=TwoWay}"/>
                            <Button
                                x:Uid="BrowseButton"
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="OnBrowseClick">
                                <FontIcon Glyph="&#xE838;" FontSize="16"/>
                            </Button>
                            <Button
                                x:Uid="SyncButton"
                                Grid.Column="2"
                                VerticalAlignment="Bottom"
                                IsEnabled="{x:Bind ViewModel.IsSyncEnabled, Mode=OneWay}"
                                Click="OnSyncClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                                    <TextBlock x:Uid="SyncButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Sync-Fortschritt direkt unter dem Pfad -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing
                                IsActive="{x:Bind ViewModel.IsSyncing, Mode=OneWay}"
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"/>
                            <TextBlock
                                Text="{x:Bind ViewModel.SyncStatusText, Mode=OneWay}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                x:Uid="EpisodeFolderPatternBox"
                                Text="{x:Bind ViewModel.EpisodeFolderPattern, Mode=TwoWay}"/>
                            <Button
                                Grid.Column="1"
                                x:Uid="AnalyzePatternButton"
                                VerticalAlignment="Bottom"
                                Click="OnAnalyzePatternClick">
                                <FontIcon Glyph="&#xE9F9;" FontSize="16"/>
                            </Button>
                        </Grid>

                        <!-- Erklärung der Platzhalter -->
                        <TextBlock
                            x:Uid="SettingsEpisodePatternHint"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,4,0,0"/>

                        <!-- Muster-Vorschläge nach Analyse -->
                        <ItemsControl
                            ItemsSource="{x:Bind ViewModel.PatternSuggestions, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.PatternSuggestionsVisibility, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:PatternSuggestionDisplay">
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Margin="0,2"
                                        Tag="{x:Bind Pattern}"
                                        Click="OnPatternSuggestionClick">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{x:Bind Pattern}" FontFamily="Consolas"/>
                                            <TextBlock
                                                Text="{x:Bind MatchCount}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button
                                x:Uid="SaveButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OnSaveClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock x:Uid="SaveButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button
                                x:Uid="CancelButton"
                                Click="OnCancelClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                    <TextBlock x:Uid="CancelButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Tab 4: Verwaltung – Cache, DB-Pflege, Reset ───────────── -->
            <TabViewItem x:Uid="TabVerwaltung" IsClosable="False">
                <ScrollViewer Padding="24,16,24,32">
                    <StackPanel Spacing="12">

                        <!-- Cache beim nächsten Start leeren -->
                        <TextBlock
                            x:Uid="CacheHeading"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,0,0,4"/>

                        <CheckBox
                            x:Uid="ClearCacheOnNextStartCheckBox"
                            IsChecked="{x:Bind ViewModel.ClearCacheOnNextStart, Mode=TwoWay}"/>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <!-- Datenbankpflege -->
                        <TextBlock
                            x:Uid="DbMaintenanceHeading"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"/>

                        <TextBlock
                            x:Uid="DbMaintenanceDescription"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"/>

                        <NumberBox
                            x:Uid="DbPurgeDaysBox"
                            Value="{x:Bind ViewModel.DbPurgeDays, Mode=OneWay}"
                            Minimum="0"
                            Maximum="3650"
                            SpinButtonPlacementMode="Inline"
                            SmallChange="1"
                            Width="200"
                            HorizontalAlignment="Left"
                            ValueChanged="OnDbPurgeDaysChanged"/>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button
                                x:Uid="DbMaintenanceButton"
                                IsEnabled="{x:Bind ViewModel.IsNotMaintaining, Mode=OneWay}"
                                Click="OnDbMaintenanceClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEF90;" FontSize="16"/>
                                    <TextBlock x:Uid="DbMaintenanceButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ProgressRing
                                IsActive="{x:Bind ViewModel.IsMaintaining, Mode=OneWay}"
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.MaintenanceStatusText, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.MaintenanceStatusVisibility, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"/>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <!-- Bibliothek zurücksetzen -->
                        <TextBlock
                            x:Uid="DbResetHeading"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Margin="0,8,0,4"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>

                        <TextBlock
                            x:Uid="DbResetDescription"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"/>

                        <RadioButtons x:Name="ResetScopeRadio" Margin="0,4,0,0">
                            <RadioButton x:Uid="ResetScopeOnline"/>
                            <RadioButton x:Uid="ResetScopeLocal"/>
                            <RadioButton x:Uid="ResetScopeAll" IsChecked="True"/>
                        </RadioButtons>

                        <Button
                            x:Uid="DbResetButton"
                            IsEnabled="{x:Bind ViewModel.IsNotMaintaining, Mode=OneWay}"
                            Margin="0,4,0,0"
                            Click="OnResetClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                                <TextBlock x:Uid="DbResetButtonLabel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,0"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button
                                x:Uid="SaveButton"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="OnSaveClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock x:Uid="SaveButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button
                                x:Uid="CancelButton"
                                Click="OnCancelClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="16"/>
                                    <TextBlock x:Uid="CancelButtonLabel" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- ── Tab 5: Protokolle – Log-Viewer mit voller Höhe ───────────── -->
            <TabViewItem x:Uid="TabProtokolle" IsClosable="False">
                <Grid Margin="24,16,24,24" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Datei-Auswahl + Live-Toggle -->
                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="LogFileComboBox"
                            x:Uid="LogFileComboBox"
                            Grid.Column="0"
                            ItemsSource="{x:Bind ViewModel.AvailableLogFiles, Mode=OneWay}"
                            DisplayMemberPath="FileName"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnLogFileSelectionChanged"/>
                        <ToggleButton
                            x:Uid="LogLiveViewToggle"
                            Grid.Column="1"
                            IsChecked="{x:Bind ViewModel.IsLiveViewActive, Mode=TwoWay}"
                            Checked="OnLiveViewChecked"
                            Unchecked="OnLiveViewUnchecked"
                            VerticalAlignment="Bottom"/>
                    </Grid>

                    <!-- Filter-Zeile: Suchtext, Level, Aktualisieren -->
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Uid="LogSearchBox"
                            Grid.Column="0"
                            Text="{x:Bind ViewModel.LogSearchText, Mode=TwoWay}"/>
                        <ComboBox
                            Grid.Column="1"
                            SelectedIndex="{x:Bind ViewModel.LogLevelFilterIndex, Mode=TwoWay}"
                            Width="130">
                            <ComboBoxItem x:Uid="LogLevelAll"/>
                            <ComboBoxItem x:Uid="LogLevelInfo"/>
                            <ComboBoxItem x:Uid="LogLevelWarning"/>
                            <ComboBoxItem x:Uid="LogLevelError"/>
                        </ComboBox>
                        <Button
                            x:Uid="LogRefreshButton"
                            Grid.Column="2"
                            Click="OnRefreshLogsClick">
                            <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                        </Button>
                    </Grid>

                    <!-- Log-Einträge: selektierbar, kopierbar, Zeilenumbruch -->
                    <Border
                        Grid.Row="2"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ScrollViewer
                            x:Name="LogScrollViewer"
                            VerticalScrollBarVisibility="Visible"
                            HorizontalScrollBarVisibility="Disabled">
                            <RichTextBlock
                                x:Name="LogRichTextBlock"
                                FontFamily="Consolas"
                                FontSize="11"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap"
                                Padding="8,6"/>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabViewItem>

        </TabView>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipSettings"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>

</Page>
