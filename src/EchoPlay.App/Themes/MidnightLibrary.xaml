<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- MidnightLibrary ist ein dunkles Theme – beide Dictionaries zeigen dieselbe Palette.
             RequestedTheme wird vom ThemeService auf Dark gesetzt. -->

        <!-- Light-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht. -->
        <ResourceDictionary x:Key="Light">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#12141D"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#1B1E2B"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#1B1E2B"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#12141D"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#22263A"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#22263A"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#1B1E2B"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#E2E4F3"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#9499C3"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#7577A5"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#555B86"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#22263A"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#2A2F4A"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#5B4DFF"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#7A75FF"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#3F39D6"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                   Color="#12141D"/>
            <SolidColorBrush x:Key="SurfaceBrush"                         Color="#12141D"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                 Color="#1B1E2B"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                    Color="#22263A"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                     Color="#E2E4F3"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                   Color="#9499C3"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                    Color="#7577A5"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                    Color="#555B86"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                   Color="#5B4DFF"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"              Color="#7A75FF"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"            Color="#3F39D6"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"           Color="#2A2560"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                Color="#5B4DFF"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"           Color="#7A75FF"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"         Color="#3F39D6"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"        Color="#2A2F4A"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                  Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"             Color="#22263A"/>
            <SolidColorBrush x:Key="CardBorderBrush"                      Color="#2A2F4A"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                 Color="#1B1E2B"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"            Color="#22263A"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"            Color="#1B1E2B"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"         Color="#161925"/>
            <SolidColorBrush x:Key="InputBorderBrush"                     Color="#2A2F4A"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                Color="#3A3F61"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                Color="#5B4DFF"/>
            <SolidColorBrush x:Key="HighlightBrush"                       Color="#232756"/>
            <SolidColorBrush x:Key="ActiveBrush"                          Color="#5B4DFF"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                Color="#232756"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"             Color="#2A2F63"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                 Color="#5B4DFF"/>
            <FontFamily x:Key="ThemeFontFamily">Source Sans 3</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">JetBrains Mono</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Source Sans 3</FontFamily>

        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">

            <!-- WinUI 3-Ressourcen überschreiben -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#12141D"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#1B1E2B"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#1B1E2B"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#12141D"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#22263A"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#22263A"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#1B1E2B"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#E2E4F3"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#9499C3"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#7577A5"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#555B86"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#22263A"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#2A2F4A"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#5B4DFF"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#7A75FF"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#3F39D6"/>

            <!-- Background / Surfaces -->
            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="#12141D"/>
            <SolidColorBrush x:Key="SurfaceBrush"           Color="#12141D"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="#1B1E2B"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"      Color="#22263A"/>

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#E2E4F3"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9499C3"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#7577A5"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#555B86"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Accent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#5B4DFF"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#7A75FF"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#3F39D6"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#2A2560"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#5B4DFF"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#7A75FF"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#3F39D6"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#2A2F4A"/>

            <!-- Cards -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#1B1E2B"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#22263A"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#2A2F4A"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#1B1E2B"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#22263A"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#1B1E2B"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#161925"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#2A2F4A"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#3A3F61"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#5B4DFF"/>

            <!-- Selection / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#232756"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#5B4DFF"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#232756"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#2A2F63"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#5B4DFF"/>

            <!-- Typografie: Source Sans 3 (ruhig, hochwertig, leicht editorial) -->
            <!-- Download: https://fonts.google.com/specimen/Source+Sans+3 -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">Source Sans 3</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">JetBrains Mono</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Source Sans 3</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
