<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Pages.StatistikPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hilfe -->
        <Button x:Name="HelpButton" Click="OnHelpClick"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Background="Transparent" Padding="6" Canvas.ZIndex="1">
            <FontIcon Glyph="&#xE897;" FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <!-- Überschrift -->
        <TextBlock
            Grid.Row="0"
            x:Uid="StatistikHeading"
            Style="{ThemeResource TitleTextBlockStyle}"
            Margin="0,0,0,16"/>

        <!-- Kennzahlen-Kacheln -->
        <StackPanel Grid.Row="1" Spacing="16">

            <!-- Sammlung -->
            <StackPanel Spacing="4">
                <TextBlock
                    x:Uid="StatistikSammlungHeading"
                    Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Text="{x:Bind ViewModel.SeriesCount, Mode=OneWay}"
                            Style="{ThemeResource TitleLargeTextBlockStyle}"/>
                        <TextBlock
                            x:Uid="StatistikSerien"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Text="{x:Bind ViewModel.EpisodeCount, Mode=OneWay}"
                            Style="{ThemeResource TitleLargeTextBlockStyle}"/>
                        <TextBlock
                            x:Uid="StatistikFolgen"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Hörfortschritt -->
            <StackPanel Spacing="4">
                <TextBlock
                    x:Uid="StatistikFortschrittHeading"
                    Style="{ThemeResource SubtitleTextBlockStyle}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                    Style="{ThemeResource BodyTextBlockStyle}"/>
                <ProgressBar
                    Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                    Maximum="100"
                    IsIndeterminate="False"
                    Margin="0,4,0,0"/>
                <Grid ColumnSpacing="24" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Text="{x:Bind ViewModel.CompletedCount, Mode=OneWay}"
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Foreground="LimeGreen"/>
                        <TextBlock
                            x:Uid="StatistikGehoert"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Text="{x:Bind ViewModel.InProgressCount, Mode=OneWay}"
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock
                            x:Uid="StatistikAngefangen"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Lade-Indikator -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <TeachingTip x:Name="HelpTip"
                     x:Uid="HelpTipStatistik"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>
</Page>
