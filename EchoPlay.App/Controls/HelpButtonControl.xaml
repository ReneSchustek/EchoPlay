<?xml version="1.0" encoding="utf-8"?>
<!-- Wiederverwendbarer Hilfe-Button mit angedocktem TeachingTip.
     Wird in allen Hauptseiten (Dashboard, Mediathek, Suche, Player, Settings, Statistik)
     verwendet und kapselt Button + TeachingTip + Click-Handler in einem Element.
     Der Aufrufer setzt nur TipUid – der lokalisierte Subtitle wird daraus abgeleitet. -->
<UserControl
    x:Class="EchoPlay.App.Controls.HelpButtonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Button x:Name="HelpButton"
                Click="OnHelpClick"
                Background="Transparent"
                Padding="6">
            <FontIcon Glyph="&#xE897;"
                      FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Button>

        <TeachingTip x:Name="HelpTip"
                     Target="{x:Bind HelpButton}"
                     PreferredPlacement="BottomLeft"
                     IsLightDismissEnabled="True"/>
    </Grid>
</UserControl>
