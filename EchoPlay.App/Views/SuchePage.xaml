<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EchoPlay.App.Views.SuchePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:EchoPlay.App.ViewModels"
    xmlns:ctrl="using:EchoPlay.App.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hilfe -->
        <ctrl:HelpButtonControl TipUid="HelpTipSuche"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,16,0" Canvas.ZIndex="1"/>

        <!-- Onboarding-Hinweis: erscheint beim ersten Start wenn noch keine Serien vorhanden sind -->
        <InfoBar
            Grid.Row="0"
            x:Uid="SucheFirstRunHint"
            IsOpen="{x:Bind ViewModel.IsOnboardingHintVisible, Mode=OneWay}"
            IsClosable="False"
            Severity="Informational"
            Margin="16,8,16,0"/>

        <!-- Suchleiste mit Suchbereich-Auswahl -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Padding="16,12,16,8">
            <AutoSuggestBox
                x:Uid="SucheSearchBox"
                QueryIcon="Find"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                Width="340"
                QuerySubmitted="OnQuerySubmitted"/>

            <!-- Scope-Auswahl: Alle Quellen / Online / Lokal -->
            <ComboBox
                x:Uid="SucheScopeComboBox"
                SelectedIndex="{x:Bind ViewModel.SelectedScopeIndex, Mode=TwoWay}"
                VerticalAlignment="Center">
                <ComboBoxItem x:Uid="SucheScopeBoth"/>
                <ComboBoxItem x:Uid="SucheScopeOnline"/>
                <ComboBoxItem x:Uid="SucheScopeLocal"/>
            </ComboBox>

            <Button
                x:Uid="SucheButton"
                Command="{x:Bind ViewModel.SearchCommand}">
                <FontIcon Glyph="&#xE721;" FontSize="16"/>
            </Button>

            <!-- X-Button: Suchfeld und Ergebnisse zurücksetzen -->
            <Button
                ToolTipService.ToolTip="Suche zurücksetzen"
                Command="{x:Bind ViewModel.ResetCommand}">
                <FontIcon Glyph="&#xE711;" FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Erfolgshinweis nach dem Hinzufügen einer Serie -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.ShowSuccessHint, Mode=OneWay}"
            Severity="Success"
            IsClosable="True"
            Margin="16,52,16,0"
            VerticalAlignment="Top">
            <InfoBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Uid="SucheAddedSuccess" VerticalAlignment="Center"/>
                    <Button
                        x:Uid="SucheGoToMediathek"
                        Click="OnGoToMediathekClick"/>
                </StackPanel>
            </InfoBar.Content>
        </InfoBar>

        <!-- Ergebnisbereich -->
        <Grid Grid.Row="2">

            <!-- Lade-Indikator: überlagert die Liste während der Anfrage -->
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>

            <!-- Leer-Hinweis: nur sichtbar wenn gesucht wurde und keine Treffer vorliegen -->
            <ctrl:EmptyStatePanel
                x:Uid="SucheEmptyState"
                Glyph="&#xE721;"
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"/>

            <!-- Kachelgitter der Suchergebnisse -->
            <GridView
                ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                SelectionMode="None"
                Padding="16,0">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultViewModel">
                        <Grid Width="160" Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Coverbild der Serie -->
                            <Border
                                Grid.Row="0"
                                Width="160" Height="160"
                                CornerRadius="6"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Image
                                    Source="{x:Bind CoverImage}"
                                    Stretch="UniformToFill"/>
                            </Border>

                            <!-- Herkunfts-Badge: zeigt an, ob das Ergebnis online oder aus der lokalen Bibliothek stammt -->
                            <Border
                                Grid.Row="0"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="4"
                                Padding="5,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="6">
                                <TextBlock
                                    Text="{x:Bind SourceLabel}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>

                            <!-- Serientitel -->
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Title}"
                                TextWrapping="Wrap"
                                MaxLines="2"
                                Margin="0,6,0,0"/>

                            <!-- Import-Schaltfläche: nur sichtbar wenn noch nicht importiert -->
                            <Button
                                Grid.Row="2"
                                x:Uid="SucheImportButton"
                                Command="{x:Bind ImportCommand}"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{x:Bind ImportButtonVisibility, Mode=OneWay}"/>

                            <!-- Bereits-importiert-Hinweis: erscheint nach erfolgreichem Import -->
                            <TextBlock
                                Grid.Row="2"
                                x:Uid="SucheAlreadyImported"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                Margin="0,4,0,0"
                                Visibility="{x:Bind AlreadyImportedVisibility, Mode=OneWay}"/>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </Grid>

    </Grid>

</Page>
