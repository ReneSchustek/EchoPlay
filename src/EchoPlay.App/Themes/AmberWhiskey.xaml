<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- AmberWhiskey ist ein dunkles Theme – beide Dictionaries zeigen dieselbe Palette.
             RequestedTheme wird vom ThemeService auf Dark gesetzt. -->

        <!-- Light-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht. -->
        <ResourceDictionary x:Key="Light">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#1A1410"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#241B16"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#241B16"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#1A1410"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#2E231C"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#2E231C"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#241B16"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#F3E9DC"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#BFA58A"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#A58C73"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#8C735C"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#2E231C"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#3A2A1F"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#C27A2C"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#D48A3A"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#9B5F20"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                   Color="#1A1410"/>
            <SolidColorBrush x:Key="SurfaceBrush"                         Color="#1A1410"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                 Color="#241B16"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                    Color="#2E231C"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                     Color="#F3E9DC"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                   Color="#BFA58A"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                    Color="#A58C73"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                    Color="#8C735C"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                   Color="#C27A2C"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"              Color="#D48A3A"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"            Color="#9B5F20"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"           Color="#4A2E10"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                Color="#C27A2C"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"           Color="#D48A3A"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"         Color="#9B5F20"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"        Color="#2C1E10"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                  Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"             Color="#2E231C"/>
            <SolidColorBrush x:Key="CardBorderBrush"                      Color="#3A2A1F"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                 Color="#241B16"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"            Color="#291F18"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"            Color="#241B16"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"         Color="#1E1610"/>
            <SolidColorBrush x:Key="InputBorderBrush"                     Color="#3A2A1F"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                Color="#4D3829"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                Color="#C27A2C"/>
            <SolidColorBrush x:Key="HighlightBrush"                       Color="#6B3E1A"/>
            <SolidColorBrush x:Key="ActiveBrush"                          Color="#C27A2C"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                Color="#3A2410"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"             Color="#3A2410"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                 Color="#C27A2C"/>
            <FontFamily x:Key="ThemeFontFamily">Merriweather Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Source Code Pro</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Merriweather Sans</FontFamily>

        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">

            <!-- WinUI 3-Ressourcen überschreiben -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#1A1410"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#241B16"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#241B16"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#1A1410"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"           Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"  Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#2E231C"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"         Color="#2E231C"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"       Color="#241B16"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"            Color="#F3E9DC"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"          Color="#BFA58A"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"           Color="#A58C73"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"           Color="#8C735C"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"       Color="#2E231C"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"          Color="#3A2A1F"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"          Color="#C27A2C"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"        Color="#D48A3A"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"         Color="#9B5F20"/>

            <!-- Background / Surfaces -->
            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="#1A1410"/>
            <SolidColorBrush x:Key="SurfaceBrush"           Color="#1A1410"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"   Color="#241B16"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"      Color="#2E231C"/>

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F3E9DC"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#BFA58A"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#A58C73"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#8C735C"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Accent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#C27A2C"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#D48A3A"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#9B5F20"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#4A2E10"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#C27A2C"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#D48A3A"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#9B5F20"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#2C1E10"/>

            <!-- Cards -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#241B16"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#2E231C"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#3A2A1F"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#241B16"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#291F18"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#241B16"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#1E1610"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#3A2A1F"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#4D3829"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#C27A2C"/>

            <!-- Selection / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#6B3E1A"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#C27A2C"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#3A2410"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#3A2410"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#C27A2C"/>

            <!-- Typografie: Merriweather Sans (warm, hochwertig, elegant) -->
            <!-- Download: https://fonts.google.com/specimen/Merriweather+Sans -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">Merriweather Sans</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">Source Code Pro</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Merriweather Sans</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
