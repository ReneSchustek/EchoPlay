<Project>
  <!--
    Zentrale Build-Konfiguration für alle Projekte in dieser Solution.
    Einzelne .csproj-Dateien k��nnen diese Werte überschreiben.
  -->
  <PropertyGroup>
    <!-- Nullability: Null-Reference-Warnungen als Fehler -->
    <Nullable>enable</Nullable>
    <!-- Moderne using-Direktiven automatisch -->
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Alle Warnungen sind Fehler -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <!-- Alle Analyzer-Regeln aktiv (Zero-Warnings-Regel) -->
    <AnalysisMode>All</AnalysisMode>
    <!-- Code-Style in Build erzwingen -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <!-- XML-Dokumentation generieren (für IntelliSense) -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Test-Projekte: xUnit-Konventionen (Unterstriche in Testnamen) -->
  <PropertyGroup Condition="$(MSBuildProjectName.EndsWith('.Tests'))">
    <NoWarn>$(NoWarn);CA1707</NoWarn>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>


  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
