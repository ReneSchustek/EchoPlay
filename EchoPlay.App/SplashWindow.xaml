<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EchoPlay.App.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="EchoPlay">

    <Grid Background="#1A1B2E">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16">

            <Image
                Source="ms-appx:///Assets/logo.png"
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                Stretch="Uniform"/>

            <TextBlock
                Text="EchoPlay"
                FontSize="30"
                FontWeight="Bold"
                Foreground="#FFFFFF"
                HorizontalAlignment="Center"/>

            <TextBlock
                Text="Deine Hörspielwelt"
                FontSize="13"
                Foreground="#8080AA"
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Name="VersionTextBlock"
                FontSize="11"
                Foreground="#555577"
                HorizontalAlignment="Center"/>

            <ProgressBar
                IsIndeterminate="True"
                Width="200"
                Margin="0,8,0,0"
                Foreground="#5B4DFF"/>

            <TextBlock
                x:Name="StatusTextBlock"
                FontSize="11"
                Foreground="#8080AA"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"/>

        </StackPanel>
    </Grid>

</Window>
