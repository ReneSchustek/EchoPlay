<?xml version="1.0" encoding="utf-8"?>
<!-- Wiederverwendbare Serien-Kachel (140×140) mit Cover, Text-Overlay und optionalen Buttons.
     Wird in lokaler und Online-Mediathek identisch verwendet – DRY statt duplizierter DataTemplates.
     Optionales V-Icon unter der Kachel zeigt die aktive Serie im Akkordeon. -->
<UserControl
    x:Class="EchoPlay.App.Controls.SeriesTileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <Grid Width="140" Height="140" Margin="4" CornerRadius="4">
            <Grid.Clip>
                <RectangleGeometry Rect="0,0,140,140"/>
            </Grid.Clip>

            <!-- Cover-Bild -->
            <Image
                x:Name="CoverImageElement"
                Stretch="UniformToFill"/>

            <!-- Platzhalter wenn kein Cover -->
            <Border
                x:Name="PlaceholderBorder"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <FontIcon
                    Glyph="&#xE8D6;"
                    FontSize="48"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Border>

            <!-- Text-Overlay unten -->
            <Border
                VerticalAlignment="Bottom"
                Background="#AA000000"
                CornerRadius="0,0,4,4"
                Padding="6,4">
                <StackPanel>
                    <TextBlock
                        x:Name="TitleText"
                        Foreground="White"
                        FontSize="12"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis"/>
                    <TextBlock
                        x:Name="SubtitleText"
                        Foreground="#BBFFFFFF"
                        FontSize="10"/>
                </StackPanel>
            </Border>

            <!-- Favoriten-Button oben links -->
            <Button
                x:Name="FavoriteButton"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Width="28" Height="28" Padding="0"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="4,4,0,0" CornerRadius="4"
                Background="#88000000" Foreground="Gold"
                FontSize="14"
                Visibility="Collapsed"/>

            <!-- Überwachungs-Icon oben links unterhalb des Favoriten-Sterns -->
            <Button
                x:Name="WatchedIndicator"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Width="28" Height="28" Padding="0"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="4,36,0,0" CornerRadius="4"
                Background="#88000000" Foreground="White"
                FontSize="14"
                IsHitTestVisible="False"
                Visibility="Collapsed"/>

            <!-- Kontextmenü-Button oben rechts -->
            <Button
                x:Name="ContextMenuButton"
                Content="&#xE712;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Width="28" Height="28" Padding="0"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,4,0" CornerRadius="4"
                Background="#88000000" Foreground="White"/>
        </Grid>

        <!-- V-Pfeil unter der Kachel – zeigt an welche Serie im Akkordeon aufgeklappt ist -->
        <FontIcon
            x:Name="SelectedIndicator"
            Glyph="&#xE70D;"
            FontSize="12"
            HorizontalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Visibility="Collapsed"/>
    </StackPanel>
</UserControl>
