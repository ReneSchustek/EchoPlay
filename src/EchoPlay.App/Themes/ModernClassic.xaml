<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!--
            ModernClassic – minimalistisch, luftig, klar.
            Kernmerkmal: weiße Navigations-Pane geht nahtlos in den weißen Inhaltsbereich über.
            Kein visueller Bruch zwischen Pane und Inhalt – die Struktur entsteht durch
            Typografie und feine Linien statt durch Farbflächen.
            Beide Dictionaries (Light/Dark) sind identisch – ModernClassic ist ein festes Helles Theme,
            der ThemeService setzt RequestedTheme=Light.
        -->

        <ResourceDictionary x:Key="Light">

            <!-- ── App-Hintergrund ─────────────────────────────────────────────── -->
            <!--
                Reines Weiß als Basis – der Kontrast zum Ruhrcoder-Grau ist sofort spürbar.
                Keine Farbflächen, Struktur entsteht durch Schatten und Ränder.
            -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceBrush"                        Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                   Color="#F3F4F6"/>

            <!-- ── NavigationView-Pane: weiß, nahtlos ────────────────────────── -->
            <!--
                Gleiche Farbe wie der App-Hintergrund – kein visueller Schnitt zwischen
                Pane und Inhaltsbereich. Die Navigation "verschwindet" im Raum.
                Der einzige Hinweis auf die Trennung ist der Selection-Indicator.
            -->
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewPaneBorderBrush"        Color="Transparent"/>

            <!-- Pane-Items: dunkle Schrift auf weißem Grund – kein Override nötig,
                 aber explizit gesetzt damit beide Themes konsistent dieselben Keys definieren -->
            <SolidColorBrush x:Key="NavigationViewItemForeground"                        Color="#374151"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver"             Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed"                 Color="#1F2937"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected"                Color="#4361EE"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver"     Color="#3451D1"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed"         Color="#2B42B8"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundDisabled"                Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedDisabled"        Color="#9CA3AF"/>

            <!-- Icon-Foregrounds: gleiche Logik wie Item-Foregrounds -->
            <SolidColorBrush x:Key="NavigationViewItemIconForeground"                    Color="#374151"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver"         Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed"             Color="#1F2937"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelected"            Color="#4361EE"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPointerOver" Color="#3451D1"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPressed"     Color="#2B42B8"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundDisabled"            Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedDisabled"    Color="#9CA3AF"/>

            <!-- Item-Hintergründe im Pane: sehr dezente Hover-/Selektion-Markierungen -->
            <SolidColorBrush x:Key="NavigationViewItemBackground"                        Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"             Color="#F3F4F6"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"                 Color="#E5E7EB"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"                Color="#EEF2FF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver"     Color="#E0E7FF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed"         Color="#C7D2FE"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"                Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedDisabled"        Color="#F5F7FF"/>

            <!-- Selektion-Indicator: Indigo-Akzent als einziges Farb-Signal in der Pane -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#4361EE"/>

            <!-- Header/Footer-Tasten in der Pane (Back-Button, Hamburger) -->
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver" Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed"     Color="#374151"/>

            <!-- ── WinUI-Standard-Overrides ───────────────────────────────────── -->
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F9FAFB"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"          Color="#F3F4F6"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"        Color="#FFFFFF"/>

            <!-- Text: moderat, nicht zu aggressiv – etwas weicher als Ruhrcoder -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"   Color="#1F2937"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#6B7280"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"  Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"  Color="#D1D5DB"/>

            <!-- Trennlinien: sehr fein, kaum sichtbar – "less is more" -->
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#E5E7EB"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"    Color="#E5E7EB"/>

            <!-- Akzent: Indigo, modern, deutlich anders als Ruhrcoder-Stahlblau -->
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#4361EE"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#5B75F2"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#364FD1"/>

            <!-- ── Eigene semantische Ressourcen ──────────────────────────────── -->

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1F2937"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextDisabledBrush"  Color="#D1D5DB"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"  Color="#FFFFFF"/>

            <!-- Akzent -->
            <SolidColorBrush x:Key="AccentPrimaryBrush"         Color="#4361EE"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"    Color="#5B75F2"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"  Color="#364FD1"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush" Color="#C7D2FE"/>

            <!-- Buttons -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush"         Color="#4361EE"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"    Color="#5B75F2"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"  Color="#364FD1"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush" Color="#E5E7EB"/>

            <!-- Karten: weißer Hintergrund mit feiner Umrandung statt Schatten -->
            <SolidColorBrush x:Key="CardBackgroundBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#F9FAFB"/>
            <SolidColorBrush x:Key="CardBorderBrush"          Color="#E5E7EB"/>

            <!--
                Semantische Karten-Header-Ressourcen.
                ModernClassic hat keinen Split-Header – alles ist weiß.
                Seiten, die CardHeaderBackgroundBrush verwenden, sehen hier keinen Farbwechsel.
                Das ist gewollt: flaches, einheitliches Kartenlayout.
            -->
            <SolidColorBrush x:Key="CardHeaderBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardHeaderForegroundBrush" Color="#1F2937"/>
            <SolidColorBrush x:Key="CardBodyBackgroundBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBodyForegroundBrush"   Color="#374151"/>

            <!-- Inputs -->
            <SolidColorBrush x:Key="InputBackgroundBrush"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"    Color="#F9FAFB"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush" Color="#F3F4F6"/>
            <SolidColorBrush x:Key="InputBorderBrush"             Color="#D1D5DB"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"        Color="#9CA3AF"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"        Color="#4361EE"/>

            <!-- Selektion / Highlight -->
            <SolidColorBrush x:Key="HighlightBrush"           Color="#4361EE"/>
            <SolidColorBrush x:Key="ActiveBrush"              Color="#4361EE"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"    Color="#EEF2FF"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#EEF2FF"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"     Color="#4361EE"/>

            <!-- Typografie: Inter – modern, neutral, hervorragende Lesbarkeit bei kleinen Größen -->
            <!-- Download: https://fonts.google.com/specimen/Inter -->
            <!-- TTF nach Assets/Fonts/ kopieren und im .csproj als Content deklarieren -->
            <FontFamily x:Key="ThemeFontFamily">Inter</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">JetBrains Mono</FontFamily>
            <!-- ContentControlThemeFontFamily überschreibt den WinUI-3-Standard,
                 damit alle built-in Styles (BodyTextBlock, Caption usw.) die Theme-Schrift verwenden -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Inter</FontFamily>

        </ResourceDictionary>

        <!--
            Dark-Key ist erforderlich, damit WinUI 3 nicht in den Fallback geht.
            ModernClassic ist ein fixes Helles Theme – identische Werte wie Light.
        -->
        <ResourceDictionary x:Key="Dark">

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppBackgroundBrush"                  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceBrush"                        Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceElevatedBrush"                Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SurfaceHoverBrush"                   Color="#F3F4F6"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground"  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewPaneBorderBrush"        Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemForeground"                        Color="#374151"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver"             Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed"                 Color="#1F2937"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected"                Color="#4361EE"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver"     Color="#3451D1"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed"         Color="#2B42B8"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundDisabled"                Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedDisabled"        Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForeground"                    Color="#374151"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver"         Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed"             Color="#1F2937"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelected"            Color="#4361EE"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPointerOver" Color="#3451D1"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPressed"     Color="#2B42B8"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundDisabled"            Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedDisabled"    Color="#9CA3AF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackground"                        Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver"             Color="#F3F4F6"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed"                 Color="#E5E7EB"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected"                Color="#EEF2FF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver"     Color="#E0E7FF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed"         Color="#C7D2FE"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"                Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedDisabled"        Color="#F5F7FF"/>
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground"          Color="#4361EE"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver"           Color="#111827"/>
            <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed"               Color="#374151"/>
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"            Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F9FAFB"/>
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"          Color="#F3F4F6"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"        Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"             Color="#1F2937"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"           Color="#6B7280"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"            Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"            Color="#D1D5DB"/>
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"        Color="#E5E7EB"/>
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"           Color="#E5E7EB"/>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush"           Color="#4361EE"/>
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"         Color="#5B75F2"/>
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"          Color="#364FD1"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"                      Color="#1F2937"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"                    Color="#6B7280"/>
            <SolidColorBrush x:Key="TextTertiaryBrush"                     Color="#9CA3AF"/>
            <SolidColorBrush x:Key="TextDisabledBrush"                     Color="#D1D5DB"/>
            <SolidColorBrush x:Key="TextOnAccentBrush"                     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"                    Color="#4361EE"/>
            <SolidColorBrush x:Key="AccentPrimaryHoverBrush"               Color="#5B75F2"/>
            <SolidColorBrush x:Key="AccentPrimaryPressedBrush"             Color="#364FD1"/>
            <SolidColorBrush x:Key="AccentPrimaryDisabledBrush"            Color="#C7D2FE"/>
            <SolidColorBrush x:Key="ButtonBackgroundBrush"                 Color="#4361EE"/>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush"            Color="#5B75F2"/>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush"          Color="#364FD1"/>
            <SolidColorBrush x:Key="ButtonBackgroundDisabledBrush"         Color="#E5E7EB"/>
            <SolidColorBrush x:Key="CardBackgroundBrush"                   Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundHoverBrush"              Color="#F9FAFB"/>
            <SolidColorBrush x:Key="CardBorderBrush"                       Color="#E5E7EB"/>
            <SolidColorBrush x:Key="CardHeaderBackgroundBrush"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardHeaderForegroundBrush"             Color="#1F2937"/>
            <SolidColorBrush x:Key="CardBodyBackgroundBrush"               Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBodyForegroundBrush"               Color="#374151"/>
            <SolidColorBrush x:Key="InputBackgroundBrush"                  Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundHoverBrush"             Color="#F9FAFB"/>
            <SolidColorBrush x:Key="InputBackgroundFocusBrush"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBackgroundDisabledBrush"          Color="#F3F4F6"/>
            <SolidColorBrush x:Key="InputBorderBrush"                      Color="#D1D5DB"/>
            <SolidColorBrush x:Key="InputBorderHoverBrush"                 Color="#9CA3AF"/>
            <SolidColorBrush x:Key="InputBorderFocusBrush"                 Color="#4361EE"/>
            <SolidColorBrush x:Key="HighlightBrush"                        Color="#4361EE"/>
            <SolidColorBrush x:Key="ActiveBrush"                           Color="#4361EE"/>
            <SolidColorBrush x:Key="ActiveBackgroundBrush"                 Color="#EEF2FF"/>
            <SolidColorBrush x:Key="SelectionBackgroundBrush"              Color="#EEF2FF"/>
            <SolidColorBrush x:Key="SelectionBorderBrush"                  Color="#4361EE"/>
            <FontFamily x:Key="ThemeFontFamily">Inter</FontFamily>
            <FontFamily x:Key="ThemeMonoFontFamily">JetBrains Mono</FontFamily>
            <FontFamily x:Key="ContentControlThemeFontFamily">Inter</FontFamily>

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
